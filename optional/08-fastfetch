set -euo pipefail

PACKAGE=fastfetch
VERSION=2.61.0

RED=$'\033[31m'
GREEN=$'\033[32m'
BLUE=$'\033[34m'
MAGENTA=$'\033[35m'
RESET=$'\033[0m'


# Error handling
die() {
    printf '%sERROR:%s %s\n' "$RED" "$RESET" "$1" >&2
    exit 1
}


# Log command
LOG_FILE="/logs/optional/$PACKAGE-$VERSION.log"

run_log() {
    if "$@" >> "$LOG_FILE" 2>&1; then
        return 0
    else
        printf '%sERROR:%s %s failed. See %s\n' "$RED" "$RESET" "$*" "$LOG_FILE" >&2
        return 1
    fi
}


[ -f "/sources/$VERSION.tar.gz" ] || die "Missing source archive: /sources/$VERSION.tar.gz"

cd /sources

rm -rf "$PACKAGE-$VERSION"
tar -xf "$VERSION.tar.gz"
cd "/sources/$PACKAGE-$VERSION"

printf '%sConfiguring %s...%s\n' "$MAGENTA" "$PACKAGE" "$RESET"
mkdir -p build
cd       build
run_log cmake -DCMAKE_INSTALL_PREFIX=/usr -G Ninja ..
printf '%sConfiguration successful!%s\n' "$GREEN" "$RESET"

printf '%sBuilding %s...%s\n' "$MAGENTA" "$PACKAGE" "$RESET"
run_log ninja
printf '%sBuild successful!%s\n' "$GREEN" "$RESET"

printf '%sPackaging %s...%s\n' "$MAGENTA" "$PACKAGE" "$RESET"
run_log env DESTDIR="/usr/pkg/$PACKAGE/$VERSION" ninja install
printf '%sPackage successful!%s\n' "$GREEN" "$RESET"

printf '%sInstalling %s...%s\n' "$MAGENTA" "$PACKAGE" "$RESET"
run_log graft -pDV "$PACKAGE/$VERSION"
run_log graft -iV "$PACKAGE/$VERSION"

run_log install -d -m755 /etc/skel/.config/fastfetch
run_log install -d -m755 /root/.config/fastfetch

cat > /etc/skel/.config/fastfetch/config.jsonc <<'EOF'
{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "none"
  },
  "display": {
    "separator": "  "
  },
  "modules": [
    "title",
    "os",
    "host",
    "kernel",
    "uptime",
    {
      "type": "command",
      "key": "Packages",
      "text": "find /usr/pkg -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | awk '{print $1}'"
    },
    "shell",
    "terminal",
    "cpu",
    "gpu",
    "memory",
    {
      "type": "disk",
      "folders": "/"
    },
    "localip",
    "colors"
  ]
}
EOF

run_log cp -f /etc/skel/.config/fastfetch/config.jsonc /root/.config/fastfetch/config.jsonc
printf '%sInstall successful!%s\n\n\n' "$GREEN" "$RESET"

cd /sources
rm -rf "$PACKAGE-$VERSION"
