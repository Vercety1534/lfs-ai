set -euo pipefail

PACKAGE=systemd
VERSION=260.1

RED=$'\033[31m'
GREEN=$'\033[32m'
BLUE=$'\033[34m'
MAGENTA=$'\033[35m'
RESET=$'\033[0m'


# Error handling
die() {
    printf '%sERROR:%s %s\n' "$RED" "$RESET" "$1" >&2
    exit 1
}


# Log command
LOG_FILE="/logs/lfs/phase5/$PACKAGE-$VERSION.log"

run_log() {
    if "$@" >> "$LOG_FILE" 2>&1; then
        return 0
    else
        printf '%sERROR:%s %s failed. See %s\n' "$RED" "$RESET" "$*" "$LOG_FILE" >&2
        return 1
    fi
}


[ -f "/sources/$PACKAGE-$VERSION.tar.gz" ] || die "Missing source archive: /sources/$PACKAGE-$VERSION.tar.gz"
[ -f "/sources/systemd-man-pages-$VERSION.tar.xz" ] || die "Missing source archive: /sources/systemd-man-pages-$VERSION.tar.xz"

cd /sources

rm -rf "$PACKAGE-$VERSION"
tar -xf "$PACKAGE-$VERSION.tar.gz"
cd "/sources/$PACKAGE-$VERSION"

printf '%sConfiguring %s...%s\n' "$MAGENTA" "$PACKAGE" "$RESET"
sed -e 's/GROUP="render"/GROUP="video"/' \
    -e 's/GROUP="sgx", //'               \
    -i rules.d/50-udev-default.rules.in

mkdir -p build
cd       build

run_log meson setup ..                \
              --prefix=/usr           \
              --buildtype=release     \
              -D default-dnssec=no    \
              -D firstboot=false      \
              -D install-tests=false  \
              -D sysusers=false       \
              -D rpmmacrosdir=no      \
              -D homed=disabled       \
              -D man=disabled         \
              -D mode=release         \
              -D pamconfdir=no        \
              -D dev-kvm-mode=0660    \
              -D nobody-group=nogroup \
              -D sysupdate=disabled   \
              -D ukify=disabled       \
              -D bpf-framework=disabled \
              -D docdir="/usr/share/doc/$PACKAGE-$VERSION"
printf '%sConfiguration successful!%s\n' "$GREEN" "$RESET"

printf '%sBuilding %s...%s\n' "$MAGENTA" "$PACKAGE" "$RESET"
run_log ninja
printf '%sBuild successful!%s\n' "$GREEN" "$RESET"

printf '%sPackaging %s...%s\n' "$MAGENTA" "$PACKAGE" "$RESET"
printf 'NAME="Linux From Scratch"\n' > /etc/os-release

run_log env DESTDIR="/usr/pkg/$PACKAGE/$VERSION" ninja install

run_log mkdir -pv "/usr/pkg/$PACKAGE/$VERSION/usr/share/man"
run_log tar -xf "../../systemd-man-pages-$VERSION.tar.xz" \
    --no-same-owner --strip-components=1     \
    -C "/usr/pkg/$PACKAGE/$VERSION/usr/share/man"

printf '%sPackage successful!%s\n' "$GREEN" "$RESET"

printf '%sInstalling %s...%s\n' "$MAGENTA" "$PACKAGE" "$RESET"
run_log graft -pDV "$PACKAGE/$VERSION"
run_log graft -iV "$PACKAGE/$VERSION"

# Fix installed hostname D-Bus alias after graft install.
run_log rm -f /usr/lib/systemd/system/dbus-org.freedesktop.hostname1.service
run_log ln -sv systemd-hostnamed.service /usr/lib/systemd/system/dbus-org.freedesktop.hostname1.service

run_log systemd-machine-id-setup
run_log systemctl preset-all

# systemctl preset-all creates an invalid autovt@tty1.service alias symlink,
# which causes a harmless but noisy getty.target warning at boot.
run_log rm -f /etc/systemd/system/getty.target.wants/autovt@tty1.service

# systemctl preset-all creates conflicting hostname-related symlinks
# under /etc/systemd/system on this build.
run_log rm -f /etc/systemd/system/dbus-org.freedesktop.hostname1.service
run_log rm -f /etc/systemd/system/systemd-hostnamed.service
run_log rm -f /etc/systemd/system/systemd-hostnamed.socket

run_log systemctl daemon-reload
printf '%sInstall successful!%s\n\n\n' "$GREEN" "$RESET"

cd /sources
rm -rf "$PACKAGE-$VERSION"
