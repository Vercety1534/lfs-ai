set -euo pipefail

PACKAGE=gcc
VERSION=15.2.0

RED=$'\033[31m'
GREEN=$'\033[32m'
BLUE=$'\033[34m'
MAGENTA=$'\033[35m'
RESET=$'\033[0m'


# Error handling
die() {
    printf '%sERROR:%s %s\n' "$RED" "$RESET" "$1" >&2
    exit 1
}


# Log command
LOG_DIR="/var/log/lfs-ai/lfs/phase2"
LOG_FILE="$LOG_DIR/$PACKAGE-$VERSION.log"

run_log() {
    if "$@" >> "$LOG_FILE" 2>&1; then
        return 0
    else
        printf '%sERROR:%s %s failed. See %s\n' "$RED" "$RESET" "$*" "$LOG_FILE" >&2
        return 1
    fi
}


[ -f "/sources/$PACKAGE-$VERSION.tar.xz" ] || die "Missing source archive: /sources/$PACKAGE-$VERSION.tar.xz"

cd /sources

rm -rf "$PACKAGE-$VERSION"
tar -xf "$PACKAGE-$VERSION.tar.xz"
cd "/sources/$PACKAGE-$VERSION"

printf '%sConfiguring %s...%s\n' "$MAGENTA" "$PACKAGE" "$RESET"
sed -i 's/char [*]q/const &/' libgomp/affinity-fmt.c

case "$(uname -m)" in
    x86_64)
        sed -e '/m64=/s/lib64/lib/' \
            -i.orig gcc/config/i386/t-linux64
    ;;
esac


mkdir -p build
cd       build

run_log env LD=ld ../configure             \
                  --prefix=/usr            \
                  --enable-languages=c,c++,cobol,fortran,go,objc,obj-c++,m2,lto \
                  --enable-default-pie     \
                  --enable-default-ssp     \
                  --enable-host-pie        \
                  --disable-multilib       \
                  --disable-bootstrap      \
                  --disable-fixincludes    \
                  --enable-plugins         \
                  --enable-lto             \
                  --with-zstd              \
                  --with-system-zlib
printf '%sConfiguration successful!%s\n' "$GREEN" "$RESET"

printf '%sBuilding %s...%s\n' "$MAGENTA" "$PACKAGE" "$RESET"
run_log make
printf '%sBuild successful!%s\n' "$GREEN" "$RESET"

printf '%sPackaging %s...%s\n' "$MAGENTA" "$PACKAGE" "$RESET"
ulimit -s -H unlimited

run_log make DESTDIR="/usr/pkg/$PACKAGE/$VERSION" install

gcc_libdir="$(find "/usr/pkg/$PACKAGE/$VERSION/usr/lib/gcc" \
    -mindepth 2 -maxdepth 2 -type d -name "$VERSION" | head -n1)"
[ -n "$gcc_libdir" ] || die "Could not locate staged GCC library directory for version $VERSION"

gcc_triplet="$(basename "$(dirname "$gcc_libdir")")"

for path in "$gcc_libdir/include" "$gcc_libdir/include-fixed"; do
    [ -e "$path" ] || continue
    run_log chown -R root:root "$path"
done

run_log install -vd "/usr/pkg/$PACKAGE/$VERSION/usr/lib"
run_log install -vd "/usr/pkg/$PACKAGE/$VERSION/usr/share/man/man1"
run_log install -vd "/usr/pkg/$PACKAGE/$VERSION/usr/lib/bfd-plugins"
run_log install -vd "/usr/pkg/$PACKAGE/$VERSION/usr/share/gdb/auto-load/usr/lib"
run_log install -vd "/usr/pkg/$PACKAGE/$VERSION/usr/share/info"

run_log ln -svfr "/usr/pkg/$PACKAGE/$VERSION/usr/bin/cpp" "/usr/pkg/$PACKAGE/$VERSION/usr/lib"
run_log ln -svf gcc.1 "/usr/pkg/$PACKAGE/$VERSION/usr/share/man/man1/cc.1"

run_log ln -svf "../../libexec/gcc/$gcc_triplet/$VERSION/liblto_plugin.so" \
    "/usr/pkg/$PACKAGE/$VERSION/usr/lib/bfd-plugins/"

for f in "/usr/pkg/$PACKAGE/$VERSION/usr/lib/"*gdb.py; do
    [ -e "$f" ] || continue
    run_log mv -v "$f" "/usr/pkg/$PACKAGE/$VERSION/usr/share/gdb/auto-load/usr/lib"
done
printf '%sPackage successful!%s\n' "$GREEN" "$RESET"

cat > "/usr/pkg/$PACKAGE/$VERSION/usr/share/info/.graft-exclude" << "EOF"
dir
EOF

printf '%sInstalling %s...%s\n' "$MAGENTA" "$PACKAGE" "$RESET"
run_log graft -pDV "$PACKAGE/$VERSION"
run_log graft -iV "$PACKAGE/$VERSION"
printf '%sInstall successful!%s\n\n\n' "$GREEN" "$RESET"

cd /sources
rm -rf "$PACKAGE-$VERSION"
