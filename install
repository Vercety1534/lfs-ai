#!/usr/bin/env bash
# LFS-AI - Linux From Scratch Automated Installer
# Copyright (c) 2026 Michael Femiak (Vercety1534)
# SPDX-License-Identifier: MIT

# Ensure Bash
if [ -z "${BASH_VERSION:-}" ]; then
    printf '\033[31mThis installer must be run with bash.\033[0m\n'
    printf 'Use: bash %s [options]\n' "$0"
    exit 1
fi

set -euo pipefail

RED=$'\033[31m'
GREEN=$'\033[32m'
BLUE=$'\033[34m'
MAGENTA=$'\033[35m'
RESET=$'\033[0m'

OPTSTRING=":Acdfhl:opstv"
called_with_args="false"
PHASE=""

base_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="$base_dir/settings.conf"


# Error handling
die() {
    printf '%sERROR:%s %s\n' "$RED" "$RESET" "$1" >&2
    exit 1
}


# Ensure root
require_root() {
    [ "$(id -u)" -eq 0 ] || die 'This installer must be run as root.'
}


# Grab version
[ -f "$base_dir/VERSION" ] || die "Missing VERSION file at $base_dir/VERSION"
VERSION="$(<"$base_dir/VERSION")"

show_version() {
    printf 'LFS-AI Installer v%s\n' "$VERSION"
    exit 0
}


# Function to display usage information
usage() {
    printf 'LFS-AI Installer v%s\n' "$VERSION"
    printf '\n'
    printf 'LFS-AI is an automated installer for Linux From Scratch.\n'
    printf 'It can run the full install or individual stages.\n'
    printf 'If a stage fails, troubleshoot it and continue from that point.\n'
    printf '\n'
    printf 'Usage: %s [-A] [-v] [-h] [-s] [-p] [-d] [-t] [-c] [-l <arg>] [-o] [-f] [--version]\n' "$0"
    printf '    -A        :  ALL   :   Complete install including drive partitioning\n'
    printf '    -v        :  DEPS  :   Verify dependencies on host system\n'
    printf '    -h        :  Help  :   Display help message\n'
    printf '\n'
    printf '    -s        : Step 1 :   Edit settings.conf (%sIMPORTANT%s - Failure to do so could destroy your system)\n' "$BLUE" "$RESET"
    printf '    -p        : Step 2 :   Prepare the host system and partition the drive\n'
    printf '    -d        : Step 3 :   Download the required source packages\n'
    printf '    -t        : Step 4 :   Install the toolchain\n'
    printf '    -c        : Step 5 :   Prepare the chroot environment\n'
    printf '    -l <arg>  : Step 6 :   Install LFS phases [1|2|3|4|5|all]\n'
    printf '    -o        : Step 7 :   Install cmake, fastfetch, and required dependencies (%sOptional%s)\n' "$BLUE" "$RESET"
    printf '    -f        : Step 8 :   Install kernel, config files, and clean up the build system\n'
    printf '\n'
    printf '    --version :        :   Display version information\n'
    printf '\n'
}


# Function to prompt user to continue
prompt_confirm() {
    local prompt="${1:-Continue?}"

    while true; do
        read -r -p "$prompt [y/N]: " REPLY
        case "$REPLY" in
            [yY]|[yY][eE][sS]) return 0 ;;
            [nN]|[nN][oO]|"") die 'Aborted by user.' ;;
            *) printf '%sERROR:%s invalid input\n' "$RED" "$RESET" ;;
        esac
    done
}

prompt_remove() {
    local prompt="${1:-Continue?}"

    while true; do
        read -r -p "$prompt [y/N]: " REPLY
        case "$REPLY" in
            [yY]|[yY][eE][sS]) return 0 ;;
            [nN]|[nN][oO]|"") return 1 ;;
            *) printf '%sERROR:%s invalid input\n' "$RED" "$RESET" ;;
        esac
    done
}


# Clear console
maybe_clear() {
    [ "${NO_CLEAR:-0}" = "1" ] && return 0
    if [ -t 1 ] && [ -n "${TERM:-}" ] && [ "$TERM" != "dumb" ]; then
        command -v clear >/dev/null 2>&1 && clear
    fi
}


# Validate settings
validate_placeholder() {
    local name="$1"
    local value="$2"

    case "$value" in
        REPLACE_ME|/dev/REPLACE_ME)
            die "$name is still set to a placeholder value."
            ;;
    esac
}

validate_drive_name() {
    local value="$1"

    validate_placeholder "DRIVE" "$value"

    case "$value" in
        /dev/sd[a-z]|/dev/vd[a-z]|/dev/xvd[a-z]|/dev/nvme[0-9]n[0-9]|/dev/mmcblk[0-9])
            ;;
        *)
            die "DRIVE must be a whole disk like /dev/sda, /dev/vda, /dev/nvme0n1, or /dev/mmcblk0. Got: $value"
            ;;
    esac

    case "$value" in
        /dev/sd[a-z][0-9]|/dev/vd[a-z][0-9]|/dev/xvd[a-z][0-9]|/dev/nvme[0-9]n[0-9]p[0-9]|/dev/mmcblk[0-9]p[0-9])
            die "DRIVE must be a whole disk, not a partition. Got: $value"
            ;;
    esac

    [ -b "$value" ] || die "DRIVE is not a real block device: $value"
}

validate_size() {
    local name="$1"
    local value="$2"
    local number

    [ -n "$value" ] || die "$name is empty."

    case "$value" in
        *[!0-9KMGT]*|"")
            die "$name must be a size like 512M, 2G, or 64G. Got: $value"
            ;;
    esac

    case "$value" in
        *[KMGT])
            ;;
        *)
            die "$name must end in K, M, G, or T. Got: $value"
            ;;
    esac

    number="${value%[KMGT]}"

    [ -n "$number" ] || die "$name is missing a numeric value. Got: $value"

    case "$number" in
        *[!0-9]*)
            die "$name must begin with digits. Got: $value"
            ;;
    esac

    [ "$number" -gt 0 ] || die "$name must be greater than 0. Got: $value"
}

validate_min_size() {
    local name="$1"
    local value="$2"
    local min_num="$3"
    local min_unit="$4"
    local number unit value_mib min_mib

    number="${value%[KMGT]}"
    unit="${value##*[0-9]}"

    case "$unit" in
        K) value_mib=$((number / 1024)) ;;
        M) value_mib="$number" ;;
        G) value_mib=$((number * 1024)) ;;
        T) value_mib=$((number * 1024 * 1024)) ;;
        *)
            die "$name has unsupported unit: $unit"
            ;;
    esac

    case "$min_unit" in
        M) min_mib="$min_num" ;;
        G) min_mib=$((min_num * 1024)) ;;
        T) min_mib=$((min_num * 1024 * 1024)) ;;
        *)
            die "Internal error: unsupported minimum unit $min_unit for $name"
            ;;
    esac

    [ "$value_mib" -ge "$min_mib" ] || die "$name must be at least ${min_num}${min_unit}. Got: $value"
}

validate_nonempty_path() {
    local name="$1"
    local value="$2"

    [ -n "$value" ] || die "$name is empty."

    case "$value" in
        /*)
            ;;
        *)
            die "$name must be an absolute path. Got: $value"
            ;;
    esac
}

validate_password() {
    local name="$1"
    local value="$2"

    validate_placeholder "$name" "$value"
    [ -n "$value" ] || die "$name is empty."
    [ "${#value}" -ge 8 ] || die "$name must be at least 8 characters long."
}

derive_partitions() {
    case "$DRIVE" in
        /dev/nvme*|/dev/mmcblk*)
            EFI="${DRIVE}p1"
            SWAP="${DRIVE}p2"
            MAIN="${DRIVE}p3"
            ;;
        /dev/sd*|/dev/vd*|/dev/xvd*)
            EFI="${DRIVE}1"
            SWAP="${DRIVE}2"
            MAIN="${DRIVE}3"
            ;;
        *)
            die "Unsupported DRIVE format: $DRIVE"
            ;;
    esac
}

validate_make_jobs() {
    local value="$1"
    local jobs

    [ -n "$value" ] || die 'MAKE_JOBS is empty.'

    case "$value" in
        -j[0-9]*)
            jobs="${value#-j}"
            ;;
        *)
            die "MAKE_JOBS must look like -j4 or -j16. Got: $value"
            ;;
    esac

    case "$jobs" in
        *[!0-9]*|"")
            die "MAKE_JOBS must contain a positive integer after -j. Got: $value"
            ;;
    esac

    [ "$jobs" -ge 1 ] || die "MAKE_JOBS must be at least -j1. Got: $value"
}

validate_config() {
    validate_drive_name "$DRIVE"

    validate_size 'EFI_SIZE' "$EFI_SIZE"
    validate_min_size 'EFI_SIZE' "$EFI_SIZE" 512 "M"

    validate_size 'SWAP_SIZE' "$SWAP_SIZE"
    validate_min_size 'SWAP_SIZE' "$SWAP_SIZE" 1 "G"

    derive_partitions

    [ "$EFI" != "$SWAP" ] || die 'EFI and SWAP must not be the same partition.'
    [ "$EFI" != "$MAIN" ] || die 'EFI and MAIN must not be the same partition.'
    [ "$SWAP" != "$MAIN" ] || die 'SWAP and MAIN must not be the same partition.'

    validate_nonempty_path 'LFS' "$LFS"

    [ "$LFS" != '/' ] || die 'LFS cannot be /'
    [ "$LFS" != '/boot' ] || die 'LFS cannot be /boot'
    [ "$LFS" != '/home' ] || die 'LFS cannot be /home'
    [ "$LFS" != '/mnt' ] || die 'LFS cannot be /mnt'
    [ "$LFS" != '/root' ] || die 'LFS cannot be /root'

    validate_password 'LFS_PASS' "$LFS_PASS"
    validate_password 'ROOT_PASS' "$ROOT_PASS"

    validate_make_jobs "$MAKE_JOBS"
}

load_config() {
    [ -f "$CONFIG_FILE" ] || die "Config file not found at $CONFIG_FILE"

    source "$CONFIG_FILE"

    validate_config
    printf '\nConfiguration loaded from %s%s%s\n' "$BLUE" "$CONFIG_FILE" "$RESET"
}


# Validate mountpoints
ensure_bind_mount() {
    local source="$1"
    local target="$2"
    local expected_source
    local actual_source
    local expected_note=''
    shift 2

    expected_source="$(findmnt -nr -o SOURCE --target "$source" 2>/dev/null || true)"

    if mountpoint -q "$target"; then
        actual_source="$(findmnt -nr -o SOURCE --target "$target" 2>/dev/null || true)"

        case "$actual_source" in
            "$source"|"$source"[[]*)
                printf '%sOK:%s    %s is bind-mounted on %s.\n' \
                    "$GREEN" "$RESET" "$source" "$target"
                ;;
            *)
                if [ -n "$expected_source" ]; then
                    expected_note=" or $expected_source"
                    case "$actual_source" in
                        "$expected_source"|"$expected_source"[[]*)
                            printf '%sOK:%s    %s is bind-mounted on %s.\n' \
                                "$GREEN" "$RESET" "$source" "$target"
                            ;;
                        *)
                            die "$target is mounted from ${actual_source:-an unknown source} instead of $source$expected_note"
                            ;;
                    esac
                else
                    die "$target is mounted from ${actual_source:-an unknown source} instead of $source"
                fi
                ;;
        esac
    else
        "$@" || die "Failed to bind-mount $source on $target"
    fi
}

ensure_mount_source() {
    local source="$1"
    local target="$2"
    shift 2

    if mountpoint -q "$target"; then
        if findmnt -nr -o SOURCE --target "$target" | grep -qx "$source"; then
            printf '%sOK:%s    %s is mounted on %s.\n' "$GREEN" "$RESET" "$source" "$target"
        else
            die "$target is already mounted, but not from $source"
        fi
    else
        "$@" || die "Failed to mount $source on $target"
    fi
}

ensure_mount_fstype() {
    local target="$1"
    local fstype="$2"
    local actual_fstype
    shift 2

    if mountpoint -q "$target"; then
        actual_fstype="$(findmnt -nr -o FSTYPE --target "$target" 2>/dev/null || true)"

        [ "$actual_fstype" = "$fstype" ] || \
            die "$target is mounted as ${actual_fstype:-unknown}, not $fstype"

        printf '%sOK:%s    %s is mounted as %s.\n' \
            "$GREEN" "$RESET" "$target" "$fstype"
    else
        "$@" || die "Failed to mount $target as $fstype"
    fi
}

ensure_dev_shm_ready() {
    local shm_target
    local shm_path

    if mountpoint -q "$LFS/dev/shm"; then
        if findmnt -nr -o FSTYPE --target "$LFS/dev/shm" | grep -qx 'tmpfs'; then
            printf '%sOK:%s    %s is mounted as tmpfs.\n' \
                "$GREEN" "$RESET" "$LFS/dev/shm"
            return 0
        fi

        die "$LFS/dev/shm is mounted, but not as tmpfs"
    fi

    if [ -h "$LFS/dev/shm" ]; then
        shm_target="$(readlink "$LFS/dev/shm")"

        case "$shm_target" in
            /*) shm_path="$LFS$shm_target" ;;
            *)  shm_path="$(dirname "$LFS/dev/shm")/$shm_target" ;;
        esac

        install -d -m 1777 "$shm_path" || \
            die 'Failed to create shared memory directory'

        [ -d "$shm_path" ] || \
            die "$LFS/dev/shm points to $shm_path, but that directory does not exist"

        [ "$(stat -c '%a' "$shm_path")" = "1777" ] || \
            die "$shm_path exists, but permissions are not 1777"

        printf '%sOK:%s    %s is a symlink and its target exists with mode 1777.\n' \
            "$GREEN" "$RESET" "$LFS/dev/shm"
        return 0
    fi

    mount -t tmpfs -o nosuid,nodev tmpfs "$LFS/dev/shm" || \
        die "Failed to mount $LFS/dev/shm"

    printf '%sOK:%s    %s is mounted as tmpfs.\n' \
        "$GREEN" "$RESET" "$LFS/dev/shm"
}

ensure_swap() {
    [ -b "$SWAP" ] || die "SWAP partition does not exist: $SWAP"

    if swapon --noheadings --show=NAME 2>/dev/null | grep -Fxq "$SWAP"; then
        printf '%sOK:%s    %s swap is active.\n' "$GREEN" "$RESET" "$SWAP"
    else
        swapon "$SWAP" || die "Failed to activate swap on $SWAP"
        printf '%sOK:%s    %s swap activated.\n' "$GREEN" "$RESET" "$SWAP"
    fi
}

ensure_build_mounts() {
    [ -b "$EFI" ]  || die "EFI partition does not exist: $EFI"
    [ -b "$SWAP" ] || die "SWAP partition does not exist: $SWAP"
    [ -b "$MAIN" ] || die "MAIN partition does not exist: $MAIN"

    [ -d "$LFS" ] || die "Missing mountpoint: $LFS"
    ensure_mount_source "$MAIN" "$LFS"      mount "$MAIN" "$LFS"

    [ -d "$LFS/boot" ] || die "Missing mountpoint: $LFS/boot"
    ensure_mount_source "$EFI"  "$LFS/boot" mount "$EFI" "$LFS/boot"

    ensure_swap
}

ensure_chroot_mounts() {
    mkdir -p "$LFS"/{dev,dev/pts,proc,sys,run}

    ensure_bind_mount "/dev" "$LFS/dev" \
        mount --bind /dev "$LFS/dev"

    ensure_mount_fstype "$LFS/dev/pts" "devpts" \
        mount -t devpts -o gid=5,mode=0620 devpts "$LFS/dev/pts"

    ensure_mount_fstype "$LFS/proc" "proc" \
        mount -t proc proc "$LFS/proc"

    ensure_mount_fstype "$LFS/sys" "sysfs" \
        mount -t sysfs sysfs "$LFS/sys"

    ensure_mount_fstype "$LFS/run" "tmpfs" \
        mount -t tmpfs tmpfs "$LFS/run"

    ensure_dev_shm_ready
}


# Phase wrapper
run_in_lfs_chroot() {
    chroot "$LFS" /usr/bin/env -i \
        HOME=/root \
        TERM="${TERM:-xterm}" \
        PS1='(lfs chroot) \u:\w\$ ' \
        PATH=/usr/bin:/usr/sbin:/bin:/sbin \
        MAKEFLAGS="$MAKE_JOBS" \
        TESTSUITEFLAGS="$MAKE_JOBS" \
        ADD_CFLAGS="${ADD_CFLAGS:-}" \
        CFLAGS="${CFLAGS:-} ${ADD_CFLAGS:-}" \
        CXXFLAGS="${CXXFLAGS:-} ${ADD_CFLAGS:-}" \
        CPPFLAGS="${CPPFLAGS:-} ${ADD_CFLAGS:-}" \
        "$@"
}

require_lfs_chroot_env() {
    [ -e "$LFS/usr/bin/env" ] || [ -L "$LFS/usr/bin/env" ] || die "Missing $LFS/usr/bin/env"
}

run_named_phase() {
    local phase="$1"
    printf '%sRunning phase %s.%s\n\n' "$MAGENTA" "$phase" "$RESET"
    [ -f "$LFS/lfs-ai/scripts/lfs-phase$phase" ] || die "Missing $LFS/lfs-ai/scripts/lfs-phase$phase"
    run_in_lfs_chroot ROOT_PASS="${ROOT_PASS:-}" /bin/bash /lfs-ai/scripts/lfs-phase"$phase"
}

graft_install_phase_pkg() {
    local phase="$1"
    local pkg="$2"
    local ver="$3"
    local LOG_FILE="$LFS/logs/lfs"
    local GRAFT_BIN="$LFS/usr/pkg/graft-2.16/usr/bin/graft"

    [ -x "$GRAFT_BIN" ] || die "Missing graft binary: $GRAFT_BIN"

    printf '%sInstalling %s...%s\n' "$MAGENTA" "$pkg" "$RESET"
    "$GRAFT_BIN" -r "$LFS" -pDV "$pkg/$ver" >> "$LOG_FILE/phase$phase/$pkg-$ver.log" 2>&1
    "$GRAFT_BIN" -r "$LFS" -iV "$pkg/$ver" >> "$LOG_FILE/phase$phase/$pkg-$ver.log" 2>&1
    printf '%sInstall successful!%s\n\n\n' "$GREEN" "$RESET"
}

run_all_lfs_phases() {
    require_lfs_chroot_env

    run_named_phase 1
    graft_install_phase_pkg 1 glibc 2.43

    run_named_phase 2
    graft_install_phase_pkg 2 ncurses 6.6

    run_named_phase 3
    graft_install_phase_pkg 3 perl 5.42.2

    run_named_phase 4
    run_named_phase 5
}

run_optional_stage() {
    [ -f "$LFS/lfs-ai/scripts/optional" ] || die "Missing $LFS/lfs-ai/scripts/optional"
    require_lfs_chroot_env
    run_in_lfs_chroot /bin/bash /lfs-ai/scripts/optional
}

run_final_stage() {
    [ -f "$LFS/lfs-ai/scripts/final" ] || die "Missing $LFS/lfs-ai/scripts/final"
    require_lfs_chroot_env
    run_in_lfs_chroot DRIVE="$DRIVE" EFI="$EFI" SWAP="$SWAP" MAIN="$MAIN" /bin/bash /lfs-ai/scripts/final
}


# Clean up ACLs
cleanup_lfs_repo_access() {
    local repo_dir="$1"
    local dir

    [ -d "$repo_dir" ] || return 0

    setfacl -R -x u:lfs "$repo_dir" 2>/dev/null || true
    setfacl -R -k "$repo_dir" 2>/dev/null || true

    dir="$(dirname "$repo_dir")"
    while [ "$dir" != "/" ]; do
        setfacl -x u:lfs "$dir" 2>/dev/null || true
        dir="$(dirname "$dir")"
    done
    setfacl -x u:lfs / 2>/dev/null || true
}


# Final Cleanup
post_final_cleanup() {
    if prompt_remove 'Do you want to remove log files?'; then
        printf '%sRemoving logs...%s\n' "$GREEN" "$RESET"
        rm -rf "$LFS/logs"
    else
        printf '%sSkipping log removal.%s\n' "$GREEN" "$RESET"
    fi

    if prompt_remove 'Do you want to remove script files?'; then
        printf '%sRemoving scripts...%s\n' "$GREEN" "$RESET"
        rm -rf "$LFS/lfs-ai"
    else
        printf '%sSkipping script removal.%s\n' "$GREEN" "$RESET"
    fi

    if prompt_remove 'Do you want to remove source files?'; then
        printf '%sRemoving sources...%s\n' "$GREEN" "$RESET"
        rm -rf "$LFS/sources"
    else
        printf '%sSkipping source removal.%s\n' "$GREEN" "$RESET"
    fi

    if id lfs >/dev/null 2>&1; then
        if prompt_remove 'Do you want to remove the lfs build user and home directory?'; then
            userdel -r lfs || die 'Failed to remove lfs user'
            printf '%sRemoved lfs user.%s\n' "$GREEN" "$RESET"
        else
            printf '%sSkipping lfs user removal.%s\n' "$GREEN" "$RESET"
        fi
    fi

    if prompt_remove 'Do you want to remove ACL entries created for the lfs user?'; then
        cleanup_lfs_repo_access "$base_dir"
        printf '%sRemoved ACL entries for lfs.%s\n' "$GREEN" "$RESET"
    else
        printf '%sSkipping ACL cleanup.%s\n' "$GREEN" "$RESET"
    fi

    [ ! -e /etc/bash.bashrc.NOUSE ] || mv /etc/bash.bashrc.NOUSE /etc/bash.bashrc
}

unmount_if_mounted() {
    local target="$1"

    if mountpoint -q "$target"; then
        umount "$target" 2>/dev/null || umount -l "$target" || die "Failed to unmount $target"
    fi
}

final_unmount_cleanup() {
    printf '%sUnmounting...%s\n' "$MAGENTA" "$RESET"

    unmount_if_mounted "$LFS/dev/shm"
    unmount_if_mounted "$LFS/dev/pts"
    unmount_if_mounted "$LFS/run"
    unmount_if_mounted "$LFS/proc"
    unmount_if_mounted "$LFS/sys"
    unmount_if_mounted "$LFS/dev"
    unmount_if_mounted "$LFS/boot"
    unmount_if_mounted "$LFS"

    if swapon --show=NAME 2>/dev/null | grep -Fxq "$SWAP"; then
        swapoff "$SWAP" || die "Failed to disable swap on $SWAP"
    fi
}


# Show installer version
if [ "${1:-}" = "--version" ]; then
    show_version
fi




# Main program
while getopts "$OPTSTRING" opt; do
  case "$opt" in

    A)  # Run full install
        called_with_args="true"
        require_root
        maybe_clear

        printf '%sPerforming a partition & complete install.%s\n\n' "$MAGENTA" "$RESET"

        printf 'This could be a dangerous operation!\n'
        printf 'Ensure %ssettings.conf%s is updated appropriately when asked.\n\n' "$BLUE" "$RESET"

        if prompt_confirm 'Are you ready to continue?'; then

            # Check dependencies
            printf '%sChecking dependencies on the host system.%s\n\n' "$MAGENTA" "$RESET"
            "$base_dir/scripts/verify"
            printf '%sVerified dependencies%s\n' "$GREEN" "$RESET"

            # Change settings
            maybe_clear
            printf '%sPreparing to configure settings.%s\n\n' "$MAGENTA" "$RESET"
            printf 'Copy the desired drive name from below to input into %ssettings.conf%s.\n' "$BLUE" "$RESET"
            printf 'Example %snvme1n1%s or %ssda%s\n\n' "$BLUE" "$RESET" "$BLUE" "$RESET"
            lsblk
            if prompt_confirm 'Are you ready to continue?'; then
                DEFAULTEDITOR="$(command -v nano >/dev/null 2>&1 && printf 'nano' || printf 'vi')"
                "${EDITOR:-$DEFAULTEDITOR}" "$CONFIG_FILE"
                printf '%sUpdated settings.%s\n' "$GREEN" "$RESET"

                load_config

                printf '\n%sInstallation configuration:%s\n' "$MAGENTA" "$RESET"
                printf 'Drive:           %s%s%s\n' "$BLUE" "$DRIVE" "$RESET"
                printf 'EFI partition:   %s%s%s\n' "$BLUE" "$EFI" "$RESET"
                printf 'SWAP partition:  %s%s%s\n' "$BLUE" "$SWAP" "$RESET"
                printf 'ROOT partition:  %s%s%s\n' "$BLUE" "$MAIN" "$RESET"
                printf 'EFI size:        %s%s%s\n' "$BLUE" "$EFI_SIZE" "$RESET"
                printf 'Swap size:       %s%s%s\n' "$BLUE" "$SWAP_SIZE" "$RESET"
                printf 'Mount point:     %s%s%s\n' "$BLUE" "$LFS" "$RESET"
                printf 'MAKE_JOBS:       %s%s%s\n' "$BLUE" "$MAKE_JOBS" "$RESET"
                printf 'Compiler Flags:  %s%s%s\n\n' "$BLUE" "${ADD_CFLAGS:-}" "$RESET"

                prompt_confirm 'Continue with these settings?'
            else
                exit 1
            fi

            # Prepare host & drives
            maybe_clear
            printf '%sPreparing the host system and drives.%s\n\n' "$MAGENTA" "$RESET"
            printf 'This could be a dangerous operation!\n'
            printf 'Ensure %ssettings.conf%s was updated appropriately.\n\n' "$BLUE" "$RESET"
            if prompt_confirm 'Are you ready to continue?'; then
                export DRIVE EFI SWAP MAIN EFI_SIZE SWAP_SIZE LFS LFS_PASS MAKE_JOBS
                "$base_dir/scripts/prepare"
                ensure_build_mounts
            else
                exit 1
            fi

            # Download packages
            printf '%sDownloading packages.%s\n' "$MAGENTA" "$RESET"
            export MAIN
            "$base_dir/scripts/download"

            # Install the toolchain
            printf '%sInstalling the toolchain.%s\n\n' "$MAGENTA" "$RESET"
            export LFS
            "$base_dir/scripts/toolchain"

            # Setup chroot
            printf '%sPreparing the chroot environment.%s\n\n' "$MAGENTA" "$RESET"

            printf '%sVerify mounts...%s\n' "$MAGENTA" "$RESET"
            ensure_chroot_mounts
            printf '%sVerification successful!%s\n\n' "$GREEN" "$RESET"

            export LFS MAKE_JOBS
            "$base_dir/scripts/chroot"

            # Install LFS
            printf '%sInstalling Linux from Scratch.%s\n\n' "$MAGENTA" "$RESET"
            export ROOT_PASS
            run_all_lfs_phases

            # Install optional packages
            if prompt_confirm 'Would you like to install cmake, fastfetch, and required dependencies?'; then
                run_optional_stage
            else
                printf '%sSkipping optional packages.%s\n\n' "$GREEN" "$RESET"
            fi

            # Final setup
            printf '%sInstalling kernel and cleaning up build system.%s\n\n' "$MAGENTA" "$RESET"

            run_final_stage

            post_final_cleanup

            final_unmount_cleanup

            printf '\n\n%sSuccess, Linux from Scratch is installed!%s\n' "$GREEN" "$RESET"
            printf 'After first boot, log in as root and run %slfs-ai-verify%s to verify the installation.\n\n' "$BLUE" "$RESET"

        else
            exit 1 # Exit with an error code
        fi
    ;;


    v)  # Check dependencies
        called_with_args="true"
        maybe_clear
        printf '%sChecking dependencies on the host system.%s\n\n' "$MAGENTA" "$RESET"
        "$base_dir/scripts/verify"
    ;;


    h)  # Display help
        called_with_args="true"
        maybe_clear
        usage
    ;;


    s)  # Change settings
        called_with_args="true"
        maybe_clear

        printf '%sPreparing to configure settings.%s\n\n' "$MAGENTA" "$RESET"
        printf 'Copy the desired drive name from below to input into %ssettings.conf%s.\n' "$BLUE" "$RESET"
        printf 'Example %snvme1n1%s or %ssda%s\n\n' "$BLUE" "$RESET" "$BLUE" "$RESET"

        lsblk

        if prompt_confirm 'Are you ready to continue?'; then
            DEFAULTEDITOR="$(command -v nano >/dev/null 2>&1 && printf 'nano' || printf 'vi')"
            "${EDITOR:-$DEFAULTEDITOR}" "$CONFIG_FILE"

            load_config

            printf '\n%sInstallation configuration:%s\n' "$MAGENTA" "$RESET"
            printf 'Drive:           %s%s%s\n' "$BLUE" "$DRIVE" "$RESET"
            printf 'EFI partition:   %s%s%s\n' "$BLUE" "$EFI" "$RESET"
            printf 'SWAP partition:  %s%s%s\n' "$BLUE" "$SWAP" "$RESET"
            printf 'ROOT partition:  %s%s%s\n' "$BLUE" "$MAIN" "$RESET"
            printf 'EFI size:        %s%s%s\n' "$BLUE" "$EFI_SIZE" "$RESET"
            printf 'Swap size:       %s%s%s\n' "$BLUE" "$SWAP_SIZE" "$RESET"
            printf 'Mount point:     %s%s%s\n' "$BLUE" "$LFS" "$RESET"
            printf 'MAKE_JOBS:       %s%s%s\n' "$BLUE" "$MAKE_JOBS" "$RESET"
            printf 'Compiler Flags:  %s%s%s\n\n' "$BLUE" "${ADD_CFLAGS:-}" "$RESET"

            printf '%sUpdated settings.%s\n' "$GREEN" "$RESET"
        else
            exit 1
        fi
    ;;


    p)  # Prepare host & drives
        called_with_args="true"
        require_root
        maybe_clear
        printf '%sPreparing the host system and drives.%s\n\n' "$MAGENTA" "$RESET"

        printf 'This could be a dangerous operation!\n'
        printf 'Ensure %ssettings.conf%s was updated appropriately.\n\n' "$BLUE" "$RESET"

        printf 'If you reboot between install steps the drive name could change as they are not always loaded in the same order.\n'
        printf 'Check %ssettings.conf%s again if a reboot is performed.\n\n' "$BLUE" "$RESET"

        if prompt_confirm 'Are you ready to continue?'; then
            printf '%sStarting install.%s\n' "$GREEN" "$RESET"
            load_config
            export DRIVE EFI SWAP MAIN EFI_SIZE SWAP_SIZE LFS LFS_PASS MAKE_JOBS
            "$base_dir/scripts/prepare"
        else
            exit 1
        fi
    ;;


    d)  # Download packages
        called_with_args="true"
        require_root
        maybe_clear
        printf '%sDownloading packages.%s\n' "$MAGENTA" "$RESET"

        printf 'If you reboot between install steps the drive name could change as they are not always loaded in the same order.\n'
        printf 'Check %ssettings.conf%s again if a reboot is performed.\n\n' "$BLUE" "$RESET"

        if prompt_confirm 'Are you ready to continue?'; then
            load_config
            ensure_build_mounts
            export LFS
            "$base_dir/scripts/download"
        else
            exit 1
        fi
    ;;


    t)
        called_with_args="true"
        require_root
        maybe_clear
        printf '%sInstalling the toolchain.%s\n\n' "$MAGENTA" "$RESET"

        printf 'This could be a dangerous operation!\n'
        printf 'Ensure Steps 1-3 were previously complete.\n\n'

        printf 'If you reboot between install steps the drive name could change as they are not always loaded in the same order.\n'
        printf 'Check %ssettings.conf%s again if a reboot is performed.\n\n' "$BLUE" "$RESET"

        if prompt_confirm 'Are you ready to continue?'; then
            printf '%sStarting install.%s\n' "$GREEN" "$RESET"
            load_config
            ensure_build_mounts
            export LFS
            "$base_dir/scripts/toolchain"
        else
            exit 1
        fi
    ;;


    c)  # Setup chroot
        called_with_args="true"
        require_root
        maybe_clear
        printf '%sPreparing the chroot environment.%s\n\n' "$MAGENTA" "$RESET"

        printf 'This could be a dangerous operation!\n'
        printf 'Ensure %sSteps 1-4%s were previously complete.\n\n' "$BLUE" "$RESET"

        printf 'If you reboot between install steps the drive name could change as they are not always loaded in the same order.\n'
        printf 'Check %ssettings.conf%s again if a reboot is performed.\n\n' "$BLUE" "$RESET"

        if prompt_confirm 'Are you ready to continue?'; then
            printf '%sStarting install.%s\n' "$GREEN" "$RESET"
            load_config
            ensure_build_mounts
            ensure_chroot_mounts
            export LFS MAKE_JOBS
            "$base_dir/scripts/chroot"
        else
            exit 1
        fi
    ;;


    l)  # Install LFS
        called_with_args="true"
        require_root
        PHASE="$OPTARG"
        maybe_clear
        printf '%sInstalling Linux from Scratch.%s\n\n' "$MAGENTA" "$RESET"

        printf 'This could be a dangerous operation!\n'
        printf 'Ensure %sSteps 1-5%s were previously complete.\n\n' "$BLUE" "$RESET"

        printf 'If you reboot between install steps the drive name could change as they are not always loaded in the same order.\n'
        printf 'Check %ssettings.conf%s again if a reboot is performed.\n\n' "$BLUE" "$RESET"

        if prompt_confirm 'Are you ready to continue?'; then
            printf '%sStarting install.%s\n\n' "$GREEN" "$RESET"

            load_config
            export ROOT_PASS

            printf '%sVerify mounts...%s\n' "$MAGENTA" "$RESET"
            ensure_build_mounts
            ensure_chroot_mounts
            printf '%sVerification successful!%s\n\n' "$GREEN" "$RESET"

            require_lfs_chroot_env

            case "$PHASE" in
            1)
                run_named_phase 1
                graft_install_phase_pkg 1 glibc 2.43
            ;;

            2)
                run_named_phase 2
                graft_install_phase_pkg 2 ncurses 6.6
            ;;

            3)
                run_named_phase 3
                graft_install_phase_pkg 3 perl 5.42.1
            ;;

            4)
                run_named_phase 4
            ;;

            5)
                run_named_phase 5
            ;;

            all)
                printf '%sRunning all phases.%s\n\n' "$MAGENTA" "$RESET"
                run_all_lfs_phases
            ;;

            *)
                printf '%sERROR:%s No valid argument provided. See below before proceeding.\n\n' "$RED" "$RESET"
                usage
                exit 1
            ;;

            esac
        else
            exit 1
        fi
    ;;


    o) # Optional packages
        called_with_args="true"
        require_root
        maybe_clear
        printf '%sInstalling optional packages.%s\n' "$MAGENTA" "$RESET"
        printf 'This will install cmake, fastfetch, and required dependencies\n\n'

        printf 'This could be a dangerous operation!\n'
        printf 'Ensure %sSteps 1-6%s were previously complete.\n\n' "$BLUE" "$RESET"

        printf 'If you reboot between install steps the drive name could change as they are not always loaded in the same order.\n'
        printf 'Check %ssettings.conf%s again if a reboot is performed.\n\n' "$BLUE" "$RESET"

        if prompt_confirm 'Are you ready to continue?'; then
            printf '%sStarting install.%s\n\n' "$GREEN" "$RESET"

            load_config

            printf '%sVerify mounts...%s\n' "$MAGENTA" "$RESET"
            ensure_build_mounts
            ensure_chroot_mounts
            printf '%sVerification successful!%s\n\n' "$GREEN" "$RESET"

            run_optional_stage
        else
            exit 1
        fi
    ;;


    f)  # Final setup
        called_with_args="true"
        require_root
        maybe_clear
        printf '%sInstalling kernel and cleaning up build system.%s\n\n' "$MAGENTA" "$RESET"

        printf 'This could be a dangerous operation!\n'
        printf 'Ensure %sSteps 1-6%s were previously complete.\n\n' "$BLUE" "$RESET"

        printf 'If you reboot between install steps the drive name could change as they are not always loaded in the same order.\n'
        printf 'Check %ssettings.conf%s again if a reboot is performed.\n\n' "$BLUE" "$RESET"

        if prompt_confirm 'Are you ready to continue?'; then
            printf '%sStarting install.%s\n\n' "$GREEN" "$RESET"

            load_config

            printf '%sVerify mounts...%s\n' "$MAGENTA" "$RESET"
            ensure_build_mounts
            ensure_chroot_mounts
            printf '%sVerification successful!%s\n\n' "$GREEN" "$RESET"

            run_final_stage

            post_final_cleanup

            final_unmount_cleanup

            printf '\n\n%sSuccess, Linux from Scratch is installed!%s\n' "$GREEN" "$RESET"
            printf 'After first boot, log in as root and run %slfs-ai-verify%s to verify the installation.\n\n' "$BLUE" "$RESET"
        else
            exit 1
        fi
    ;;


    :)  # Require options
        called_with_args="true"
        printf '%sERROR:%s Option -%s requires an argument.\n\n' "$RED" "$RESET" "$OPTARG" >&2
        usage
        exit 1
    ;;


    ?)  # Handle invalid options
        called_with_args="true"
        printf '%sERROR:%s Invalid option: -%s\n\n' "$RED" "$RESET" "$OPTARG" >&2
        usage
        exit 1
    ;;
  esac
done


# Script can't run without options
if [[ "$called_with_args" == "false" ]]; then
    printf '%sERROR:%s No options were passed. See below before proceeding.\n' "$RED" "$RESET"
    usage
    exit 1
fi
