#!/usr/bin/env bash
# LFS-AI - Linux From Scratch Automated Installer
# Copyright (c) 2026 Michael Femiak (Vercety1534)
# SPDX-License-Identifier: MIT

set -e

RED='\033[31m'
GREEN='\033[32m'
BLUE='\033[34m'
MAGENTA='\033[35m'
RESET='\033[0m'

OPTSTRING=":Acdfhl:pstv"
called_with_args="false"
PHASE=""

base_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="$base_dir/settings.conf"


# Ensure Bash
if [ -z "${BASH_VERSION:-}" ]; then
    printf "%b\n" "${RED}This installer must be run with bash.${RESET}"
    printf "Use: bash %s [options]\n" "$0"
    exit 1
fi




# Function to display usage information
usage() {
    printf 'LFS-AI Installer v%s\n' "$VERSION"
    printf "\n"
    printf "LFS-AI is an automated installer for Linux From Scratch.\n"
    printf "It can run the full install or individual stages.\n"
    printf "If a stage fails, troubleshoot it and continue from that point.\n"
    printf "\n"
    printf "Usage: %s [-A] [-v] [-h] [-s] [-p] [-d] [-t] [-c] [-l 1|2|3|4|5|all] [-f] [--version]\n" "$0"
    printf "    -A        :  ALL   :   Complete install including drive partitioning\n"
    printf "    -v        :  DEPS  :   Verify dependencies on host system\n"
    printf "    -h        :  Help  :   Display help message\n"
    printf "\n"
    printf "    -s        : Step 1 :   Edit settings.conf (${BLUE}IMPORTANT${RESET} - Failure to do so could destroy your system)\n"
    printf "    -p        : Step 2 :   Prepare the host system and partition the drive\n"
    printf "    -d        : Step 3 :   Download the required source packages\n"
    printf "    -t        : Step 4 :   Install the toolchain\n"
    printf "    -c        : Step 5 :   Prepare the chroot environment\n"
    printf "    -l #      : Step 6 :   Install LFS [Phases - 1|2|3|4|5|all]\n"
    printf "    -f        : Step 7 :   Install kernel, config files, and clean up build system\n"
    printf "\n"
    printf "    --version :        :   Display installer version\n"
    printf "\n"
}




# Function to prompt user to continue
prompt_confirm() {
    local prompt="${1:-Continue?}"

    while true; do
        read -r -p "$prompt [y/N]: " REPLY
        case "$REPLY" in
            [yY]|[yY][eE][sS]) return 0 ;;
            [nN]|[nN][oO]|"") die "Aborted by user." ;;
            *) printf "${RED}ERROR:${RESET} invalid input\n" ;;
        esac
    done
}

prompt_remove() {
    local prompt="${1:-Continue?}"

    while true; do
        read -r -p "$prompt [y/N]: " REPLY
        case "$REPLY" in
            [yY]|[yY][eE][sS]) return 0 ;;
            [nN]|[nN][oO]|"") return 1 ;;
            *) printf "${RED}ERROR:${RESET} invalid input\n" ;;
        esac
    done
}




# Clear console
maybe_clear() {
    [ "${NO_CLEAR:-0}" = "1" ] && return 0
    if [ -t 1 ] && [ -n "${TERM:-}" ] && [ "$TERM" != "dumb" ]; then
        command -v clear >/dev/null 2>&1 && clear || true
    fi
}




# Ensure root
require_root() {
    [ "$(id -u)" -eq 0 ] || die "This installer must be run as root."
}




# Validate settings
die() {
    printf "${RED}ERROR:${RESET} %s\n" "$1" >&2
    exit 1
}

validate_placeholder() {
    local name="$1"
    local value="$2"

    case "$value" in
        REPLACE_ME|/dev/REPLACE_ME)
            die "$name is still set to a placeholder value."
            ;;
    esac
}

validate_drive_name() {
    local value="$1"

    validate_placeholder "DRIVE" "$value"

    case "$value" in
        /dev/sd[a-z]|/dev/vd[a-z]|/dev/xvd[a-z]|/dev/nvme[0-9]n[0-9]|/dev/mmcblk[0-9])
            ;;
        *)
            die "DRIVE must be a whole disk like /dev/sda, /dev/vda, /dev/nvme0n1, or /dev/mmcblk0. Got: $value"
            ;;
    esac

    case "$value" in
        /dev/sd[a-z][0-9]|/dev/vd[a-z][0-9]|/dev/xvd[a-z][0-9]|/dev/nvme[0-9]n[0-9]p[0-9]|/dev/mmcblk[0-9]p[0-9])
            die "DRIVE must be a whole disk, not a partition. Got: $value"
            ;;
    esac

    [ -b "$value" ] || die "DRIVE is not a real block device: $value"
}

validate_size() {
    local name="$1"
    local value="$2"
    local number

    [ -n "$value" ] || die "$name is empty."

    case "$value" in
        *[!0-9KMGT]*|"")
            die "$name must be a size like 512M, 2G, or 64G. Got: $value"
            ;;
    esac

    case "$value" in
        *[KMGT])
            ;;
        *)
            die "$name must end in K, M, G, or T. Got: $value"
            ;;
    esac

    number="${value%[KMGT]}"

    [ -n "$number" ] || die "$name is missing a numeric value. Got: $value"

    case "$number" in
        *[!0-9]*)
            die "$name must begin with digits. Got: $value"
            ;;
    esac

    [ "$number" -gt 0 ] || die "$name must be greater than 0. Got: $value"
}

validate_min_size() {
    local name="$1"
    local value="$2"
    local min_num="$3"
    local min_unit="$4"
    local number unit value_mib min_mib

    number="${value%[KMGT]}"
    unit="${value##*[0-9]}"

    case "$unit" in
        K) value_mib=$((number / 1024)) ;;
        M) value_mib="$number" ;;
        G) value_mib=$((number * 1024)) ;;
        T) value_mib=$((number * 1024 * 1024)) ;;
        *)
            die "$name has unsupported unit: $unit"
            ;;
    esac

    case "$min_unit" in
        M) min_mib="$min_num" ;;
        G) min_mib=$((min_num * 1024)) ;;
        T) min_mib=$((min_num * 1024 * 1024)) ;;
        *)
            die "Internal error: unsupported minimum unit $min_unit for $name"
            ;;
    esac

    [ "$value_mib" -ge "$min_mib" ] || die "$name must be at least ${min_num}${min_unit}. Got: $value"
}

validate_nonempty_path() {
    local name="$1"
    local value="$2"

    [ -n "$value" ] || die "$name is empty."

    case "$value" in
        /*)
            ;;
        *)
            die "$name must be an absolute path. Got: $value"
            ;;
    esac
}

validate_password() {
    local name="$1"
    local value="$2"

    validate_placeholder "$name" "$value"
    [ -n "$value" ] || die "$name is empty."
    [ "${#value}" -ge 8 ] || die "$name must be at least 8 characters long."
}

derive_partitions() {
    case "$DRIVE" in
        /dev/nvme*|/dev/mmcblk*)
            EFI="${DRIVE}p1"
            SWAP="${DRIVE}p2"
            MAIN="${DRIVE}p3"
            ;;
        /dev/sd*|/dev/vd*|/dev/xvd*)
            EFI="${DRIVE}1"
            SWAP="${DRIVE}2"
            MAIN="${DRIVE}3"
            ;;
        *)
            die "Unsupported DRIVE format: $DRIVE"
            ;;
    esac
}

validate_config() {
    validate_drive_name "$DRIVE"

    validate_size "EFI_SIZE" "$EFI_SIZE"
    validate_min_size "EFI_SIZE" "$EFI_SIZE" 512 "M"

    validate_size "SWAP_SIZE" "$SWAP_SIZE"
    validate_min_size "SWAP_SIZE" "$SWAP_SIZE" 1 "G"

    validate_nonempty_path "LFS" "$LFS"

    validate_password "LFS_PASS" "$LFS_PASS"
    validate_password "ROOT_PASS" "$ROOT_PASS"

    [ "$LFS" != "/" ] || die "LFS cannot be /"
    [ "$LFS" != "/boot" ] || die "LFS cannot be /boot"
    [ "$LFS" != "/home" ] || die "LFS cannot be /home"
    [ "$LFS" != "/mnt" ] || die "LFS cannot be /mnt"
    [ "$LFS" != "/root" ] || die "LFS cannot be /root"

    derive_partitions

    [ "$EFI" != "$SWAP" ] || die "EFI and SWAP must not be the same partition."
    [ "$EFI" != "$MAIN" ] || die "EFI and MAIN must not be the same partition."
    [ "$SWAP" != "$MAIN" ] || die "SWAP and MAIN must not be the same partition."
}

load_config() {
    [ -f "$CONFIG_FILE" ] || die "Config file not found at $CONFIG_FILE"

    source "$CONFIG_FILE"

    validate_config
    printf "Configuration loaded from ${BLUE}%s${RESET}\n\n" "$CONFIG_FILE"
}




# Validate mountpoints
ensure_mounted() {
    local target="$1"
    shift

    if mountpoint -q "$target"; then
        printf "${GREEN}OK:${RESET}    %s is mounted.\n" "$target"
    else
        "$@" || die "Failed to mount $target"
    fi
}

ensure_mount_source() {
    local source="$1"
    local target="$2"
    shift 2

    if mountpoint -q "$target"; then
        if findmnt -nr -o SOURCE --target "$target" | grep -qx "$source"; then
            printf "${GREEN}OK:${RESET}    %s is mounted on %s.\n" "$source" "$target"
        else
            die "$target is already mounted, but not from $source"
        fi
    else
        "$@" || die "Failed to mount $source on $target"
    fi
}

ensure_swap() {
    [ -b "$SWAP" ] || die "SWAP partition does not exist: $SWAP"

    if swapon --noheadings --show=NAME 2>/dev/null | grep -Fxq "$SWAP"; then
        printf "${GREEN}OK:${RESET}    %s swap is active.\n" "$SWAP"
    else
        swapon "$SWAP" || die "Failed to activate swap on $SWAP"
        printf "${GREEN}OK:${RESET}    %s swap activated.\n" "$SWAP"
    fi
}

ensure_lfs_layout_and_mounts() {
    [ -b "$EFI" ]  || die "EFI partition does not exist: $EFI"
    [ -b "$SWAP" ] || die "SWAP partition does not exist: $SWAP"
    [ -b "$MAIN" ] || die "MAIN partition does not exist: $MAIN"

    ensure_mount_source "$MAIN" "$LFS"      mount "$MAIN" "$LFS"
    ensure_mount_source "$EFI"  "$LFS/boot" mount "$EFI" "$LFS/boot"
    ensure_swap
    ensure_mounted "$LFS/dev"     mount --bind /dev "$LFS/dev"
    ensure_mounted "$LFS/dev/pts" mount -t devpts -o gid=5,mode=0620 devpts "$LFS/dev/pts"
    ensure_mounted "$LFS/proc"    mount -t proc proc "$LFS/proc"
    ensure_mounted "$LFS/sys"     mount -t sysfs sysfs "$LFS/sys"
    ensure_mounted "$LFS/run"     mount -t tmpfs tmpfs "$LFS/run"

    if mountpoint -q "$LFS/dev/shm"; then
        printf "${GREEN}OK:${RESET}    %s is mounted.\n" "$LFS/dev/shm"
    else
        if [ -h "$LFS/dev/shm" ]; then
            install -d -m 1777 "$LFS$(realpath /dev/shm)" || die "Failed to create shared memory directory"
        else
            mount -t tmpfs -o nosuid,nodev tmpfs "$LFS/dev/shm" || die "Failed to mount $LFS/dev/shm"
        fi
    fi
}




# Phase wrapper
run_lfs_phase() {
    local phase="$1"

    chroot "$LFS" /usr/bin/env -i              \
        HOME=/root                             \
        TERM="$TERM"                           \
        PS1='(lfs chroot) \u:\w\$ '            \
        PATH=/usr/bin:/usr/sbin:/bin:/sbin     \
        MAKEFLAGS="-j$(nproc)"                 \
        TESTSUITEFLAGS="-j$(nproc)"            \
        ADD_CFLAGS="${ADD_CFLAGS:-}"           \
        CFLAGS="${CFLAGS} ${ADD_CFLAGS:-}"     \
        CXXFLAGS="${CXXFLAGS} ${ADD_CFLAGS:-}" \
        CPPFLAGS="${CPPFLAGS} ${ADD_CFLAGS:-}" \
        ROOT_PASS="${ROOT_PASS:-}"             \
        /bin/bash "/lfs-ai/scripts/lfs-phase$phase"
}




# Show installer version
[ -f "$base_dir/VERSION" ] || die "Missing VERSION file at $base_dir/VERSION"
VERSION="$(<"$base_dir/VERSION")"

show_version() {
    printf 'LFS-AI Installer v%s\n' "$VERSION"
    exit 0
}

if [ "${1:-}" = "--version" ]; then
    show_version
fi




# Main program
while getopts "$OPTSTRING" opt; do
  case "$opt" in

    A)
      # Run all scripts
      called_with_args="true"
      require_root
      maybe_clear

      printf "${MAGENTA}Performing a partition & complete install.${RESET}\n\n"

      printf "This could be a dangerous operation!\n"
      printf "Ensure ${BLUE}settings.conf${RESET} is updated appropriately when asked.\n\n"

      if prompt_confirm "Are you ready to continue?"; then

        # Check dependencies
        printf "${MAGENTA}Checking dependencies on the host system.${RESET}\n\n"
        "$base_dir/scripts/verify"
        printf "${GREEN}Verified dependencies${RESET}\n"

        # Change settings
        maybe_clear
        printf "${MAGENTA}Preparing to configure settings.${RESET}\n\n"
        printf "Copy the desired drive name from below to input into ${BLUE}settings.conf${RESET}.\n"
        printf "Example ${BLUE}nvme1n1${RESET} or ${BLUE}sda${RESET}\n\n"
        lsblk
        if prompt_confirm "Are you ready to continue?"; then
            called_with_args="true"
            DEFAULTEDITOR="$(command -v nano >/dev/null 2>&1 && printf 'nano' || printf 'vi')"
            "${EDITOR:-$DEFAULTEDITOR}" "$CONFIG_FILE"
            printf "${GREEN}Updated Settings${RESET}\n"

            load_config

            printf "\n${MAGENTA}Installation configuration:${RESET}\n"
            printf "Drive:           ${BLUE}%s${RESET}\n" "$DRIVE"
            printf "EFI partition:   ${BLUE}%s${RESET}\n" "$EFI"
            printf "SWAP partition:  ${BLUE}%s${RESET}\n" "$SWAP"
            printf "ROOT partition:  ${BLUE}%s${RESET}\n" "$MAIN"
            printf "EFI size:        ${BLUE}%s${RESET}\n" "$EFI_SIZE"
            printf "Swap size:       ${BLUE}%s${RESET}\n" "$SWAP_SIZE"
            printf "Mount point:     ${BLUE}%s${RESET}\n" "$LFS"
            printf "Compiler Flags:  ${BLUE}%s${RESET}\n\n" "$ADD_CFLAGS"

            prompt_confirm "Continue with these settings?"
        else
            exit 1
        fi

        # Prepare host & drives
        maybe_clear
        printf "${MAGENTA}Preparing the host system and drives.${RESET}\n\n"
        printf    "This could be a dangerous operation!\n"
        printf "Ensure ${BLUE}settings.conf${RESET} was updated appropriately.\n\n"
        if prompt_confirm "Are you ready to continue?"; then
            "$base_dir/scripts/prepare"
        else
            exit 1
        fi

        # Download packages
        "$base_dir/scripts/download"

        # Install the toolchain
        printf "${MAGENTA}Installing the toolchain.${RESET}\n"
        "$base_dir/scripts/toolchain"

        # Setup chroot
        printf "${MAGENTA}Preparing the chroot environment.${RESET}\n"
        "$base_dir/scripts/chroot"

        # Install LFS
        printf "${MAGENTA}Installing Linux from Scratch.${RESET}\n\n"

        # Verify mounts
        printf "${MAGENTA}Verify mounts...${RESET}\n"
        ensure_lfs_layout_and_mounts
        printf "${GREEN}Verification successful!${RESET}\n\n"
        "$base_dir/scripts/lfs"

        # Final setup
        printf "${MAGENTA}Installing kernel and cleaning up build system.${RESET}\n"
        [ -f "$LFS/lfs-ai/scripts/final" ] || die "Missing $LFS/lfs-ai/scripts/final"
        chroot "$LFS" /usr/bin/env -i              \
            HOME=/root                             \
            TERM="$TERM"                           \
            PS1='(lfs chroot) \u:\w\$ '            \
            PATH=/usr/bin:/usr/sbin:/bin:/sbin     \
            MAKEFLAGS="-j$(nproc)"                 \
            TESTSUITEFLAGS="-j$(nproc)"            \
            ADD_CFLAGS="${ADD_CFLAGS:-}"           \
            CFLAGS="${CFLAGS} ${ADD_CFLAGS:-}"     \
            CXXFLAGS="${CXXFLAGS} ${ADD_CFLAGS:-}" \
            CPPFLAGS="${CPPFLAGS} ${ADD_CFLAGS:-}" \
            DRIVE="$DRIVE"                         \
            EFI="$EFI"                             \
            SWAP="$SWAP"                           \
            MAIN="$MAIN"                           \
            /bin/bash /lfs-ai/scripts/final

        if prompt_remove "Do you want to remove log files?"; then
            printf "${GREEN}Removing logs...${RESET}\n"
            rm -rf "$LFS/logs"
        else
            printf "${GREEN}Skipping log removal.${RESET}\n"
        fi

        if prompt_remove "Do you want to remove script files?"; then
            printf "${GREEN}Removing scripts...${RESET}\n"
            rm -rf "$LFS/lfs-ai"
        else
            printf "${GREEN}Skipping script removal.${RESET}\n"
        fi

        if prompt_remove "Do you want to remove source files?"; then
            printf "${GREEN}Removing sources...${RESET}\n"
            rm -rf "$LFS/sources"
        else
            printf "${GREEN}Skipping source removal.${RESET}\n"
        fi

        [ ! -e /etc/bash.bashrc.NOUSE ] || mv /etc/bash.bashrc.NOUSE /etc/bash.bashrc

        printf "${MAGENTA}Unmounting...${RESET}\n"

        unmount_if_mounted() {
            local target="$1"

            if mountpoint -q "$target"; then
                umount "$target" 2>/dev/null || umount -l "$target" || die "Failed to unmount $target"
            fi
        }

        unmount_if_mounted "$LFS/dev/shm"
        unmount_if_mounted "$LFS/dev/pts"
        unmount_if_mounted "$LFS/run"
        unmount_if_mounted "$LFS/proc"
        unmount_if_mounted "$LFS/sys"
        unmount_if_mounted "$LFS/dev"
        unmount_if_mounted "$LFS/boot"
        unmount_if_mounted "$LFS"

        if swapon --show=NAME 2>/dev/null | grep -Fxq "$SWAP"; then
            swapoff "$SWAP" || die "Failed to disable swap on $SWAP"
        fi

        printf "\n\n${GREEN}Success, Linux from Scratch is installed!${RESET}\n\n"

      else
        exit 1 # Exit with an error code
      fi

    ;;




    v)
      # Check dependencies
      called_with_args="true"
      maybe_clear
      printf "${MAGENTA}Checking dependencies on the host system.${RESET}\n\n"
      "$base_dir/scripts/verify"

    ;;




    h)
      # Display help
      called_with_args="true"
      usage
      exit 0
    ;;




    s)
      # Change settings
      called_with_args="true"
      maybe_clear
      printf "${MAGENTA}Preparing to configure settings.${RESET}\n\n"
      printf "Copy the desired drive name from below to input into ${BLUE}settings.conf${RESET}.\n"
      printf "Example ${BLUE}nvme1n1${RESET} or ${BLUE}sda${RESET}\n\n"

      printf "If you reboot between install steps the drive name could change as they are not always loaded in the same order.\n"
      printf "Check ${BLUE}settings.conf${RESET} again if a reboot is performed.\n\n"

      lsblk

      if prompt_confirm "Are you ready to continue?"; then
        DEFAULTEDITOR="$(command -v nano >/dev/null 2>&1 && printf 'nano' || printf 'vi')"
        "${EDITOR:-$DEFAULTEDITOR}" "$CONFIG_FILE"

        load_config

        printf "\n${MAGENTA}Installation configuration:${RESET}\n"
        printf "Drive:           ${BLUE}%s${RESET}\n" "$DRIVE"
        printf "EFI partition:   ${BLUE}%s${RESET}\n" "$EFI"
        printf "SWAP partition:  ${BLUE}%s${RESET}\n" "$SWAP"
        printf "ROOT partition:  ${BLUE}%s${RESET}\n" "$MAIN"
        printf "EFI size:        ${BLUE}%s${RESET}\n" "$EFI_SIZE"
        printf "Swap size:       ${BLUE}%s${RESET}\n" "$SWAP_SIZE"
        printf "Mount point:     ${BLUE}%s${RESET}\n" "$LFS"
        printf "Compiler Flags:  ${BLUE}%s${RESET}\n\n" "$ADD_CFLAGS"

        printf "${GREEN}Updated Settings${RESET}\n"
      else
        exit 1
      fi
    ;;




    p)
      # Prepare host & drives
      called_with_args="true"
      require_root
      maybe_clear
      printf "${MAGENTA}Preparing the host system and drives.${RESET}\n\n"

      printf "This could be a dangerous operation!\n"
      printf "Ensure ${BLUE}settings.conf${RESET} was updated appropriately.\n\n"

      printf "If you reboot between install steps the drive name could change as they are not always loaded in the same order.\n"
      printf "Check ${BLUE}settings.conf${RESET} again if a reboot is performed.\n\n"

      if prompt_confirm "Are you ready to continue?"; then
        printf "${GREEN}Starting Install${RESET}\n"
        "$base_dir/scripts/prepare"
      else
        exit 1
      fi

    ;;




    d)
      # Download packages
      called_with_args="true"
      require_root
      maybe_clear
      printf "${MAGENTA}Downloading packages.${RESET}\n"

      printf "If you reboot between install steps the drive name could change as they are not always loaded in the same order.\n"
      printf "Check ${BLUE}settings.conf${RESET} again if a reboot is performed.\n\n"

      if prompt_confirm "Are you ready to continue?"; then
        "$base_dir/scripts/download"
      else
        exit 1
      fi

    ;;




    t)
      # Install the toolchain
      called_with_args="true"
      require_root
      maybe_clear
      printf "${MAGENTA}Installing the toolchain.${RESET}\n\n"

      printf "This could be a dangerous operation!\n"
      printf "Ensure ${BLUE}Steps 1-3${RESET} were previously complete.\n\n"

      printf "If you reboot between install steps the drive name could change as they are not always loaded in the same order.\n"
      printf "Check ${BLUE}settings.conf${RESET} again if a reboot is performed.\n\n"

      if prompt_confirm "Are you ready to continue?"; then
        printf "${GREEN}Starting Install${RESET}\n"
        "$base_dir/scripts/toolchain"
      else
        exit 1
      fi

    ;;




    c)
      # Setup chroot
      called_with_args="true"
      require_root
      maybe_clear
      printf "${MAGENTA}Preparing the chroot environment.${RESET}\n\n"

      printf "This could be a dangerous operation!\n"
      printf "Ensure ${BLUE}Steps 1-4${RESET} were previously complete.\n\n"

      printf "If you reboot between install steps the drive name could change as they are not always loaded in the same order.\n"
      printf "Check ${BLUE}settings.conf${RESET} again if a reboot is performed.\n\n"

      if prompt_confirm "Are you ready to continue?"; then
        printf "${GREEN}Starting Install${RESET}\n"
        "$base_dir/scripts/chroot"
      else
        exit 1
      fi

    ;;




    l)
      # Install LFS
      called_with_args="true"
      require_root
      PHASE="$OPTARG"
      maybe_clear
      printf "${MAGENTA}Installing Linux from Scratch.${RESET}\n\n"

      printf "This could be a dangerous operation!\n"
      printf "Ensure ${BLUE}Steps 1-5${RESET} were previously complete.\n\n"

      printf "If you reboot between install steps the drive name could change as they are not always loaded in the same order.\n"
      printf "Check ${BLUE}settings.conf${RESET} again if a reboot is performed.\n\n"


      if prompt_confirm "Are you ready to continue?"; then
        printf "${GREEN}Starting Install${RESET}\n\n"

        load_config

        LOG_FILE="$LFS/logs/lfs"

        printf "${MAGENTA}Verify mounts...${RESET}\n"
        ensure_lfs_layout_and_mounts
        printf "${GREEN}Verification successful!${RESET}\n\n"

        GRAFT_BIN="$LFS/usr/pkg/graft-2.16/usr/bin/graft"
        [ -x "$GRAFT_BIN" ] || die "Missing graft binary: $GRAFT_BIN"
        [ -e "$LFS/usr/bin/env" ] || [ -L "$LFS/usr/bin/env" ] || die "Missing $LFS/usr/bin/env"

        case "$PHASE" in

          1)
            printf "${MAGENTA}Running phase %s.${RESET}\n\n" "$PHASE"
            [ -f "$LFS/lfs-ai/scripts/lfs-phase1" ] || die "Missing $LFS/lfs-ai/scripts/lfs-phase1"

            run_lfs_phase 1

            printf "${MAGENTA}Installing glibc...${RESET}\n"
            "$GRAFT_BIN" -r "$LFS" -pDV glibc/2.43 >> "$LOG_FILE/phase1/glibc-2.43.log" 2>&1
            "$GRAFT_BIN" -r "$LFS" -iV glibc/2.43 >> "$LOG_FILE/phase1/glibc-2.43.log" 2>&1
            printf "${GREEN}Install successful!${RESET}\n"
          ;;

          2)
            printf "${MAGENTA}Running phase %s.${RESET}\n\n" "$PHASE"
            [ -f "$LFS/lfs-ai/scripts/lfs-phase2" ] || die "Missing $LFS/lfs-ai/scripts/lfs-phase2"

            run_lfs_phase 2

            printf "${MAGENTA}Installing ncurses...${RESET}\n"
            "$GRAFT_BIN" -r "$LFS" -pDV ncurses/6.6 >> "$LOG_FILE/phase2/ncurses-6.6.log" 2>&1
            "$GRAFT_BIN" -r "$LFS" -iV ncurses/6.6 >> "$LOG_FILE/phase2/ncurses-6.6.log" 2>&1
            printf "${GREEN}Install successful!${RESET}\n"
          ;;

          3)
            printf "${MAGENTA}Running phase %s.${RESET}\n\n" "$PHASE"
            [ -f "$LFS/lfs-ai/scripts/lfs-phase3" ] || die "Missing $LFS/lfs-ai/scripts/lfs-phase3"

            run_lfs_phase 3

            printf "${MAGENTA}Installing perl...${RESET}\n"
            "$GRAFT_BIN" -r "$LFS" -pDV perl/5.42.1 >> "$LOG_FILE/phase3/perl-5.42.1.log" 2>&1
            "$GRAFT_BIN" -r "$LFS" -iV perl/5.42.1 >> "$LOG_FILE/phase3/perl-5.42.1.log" 2>&1
            printf "${GREEN}Install successful!${RESET}\n"
          ;;

          4)
            printf "${MAGENTA}Running phase %s.${RESET}\n\n" "$PHASE"
            [ -f "$LFS/lfs-ai/scripts/lfs-phase4" ] || die "Missing $LFS/lfs-ai/scripts/lfs-phase4"

            run_lfs_phase 4
          ;;

          5)
            printf "${MAGENTA}Running phase %s.${RESET}\n\n" "$PHASE"
            [ -f "$LFS/lfs-ai/scripts/lfs-phase5" ] || die "Missing $LFS/lfs-ai/scripts/lfs-phase5"

            run_lfs_phase 5
          ;;

          all)
            printf "${MAGENTA}Running %s phases.${RESET}\n\n" "$PHASE"
            "$base_dir/scripts/lfs"
          ;;

          *)
            printf "ERROR: No valid argument provided. See below before proceeding.\n\n"
            usage
            exit 1
          ;;

        esac
      else
        exit 1
      fi

    ;;




    f)
      # Final setup
      called_with_args="true"
      require_root
      maybe_clear
      printf "${MAGENTA}Installing kernel and cleaning up build system.${RESET}\n\n"

      printf "This could be a dangerous operation!\n"
      printf "Ensure ${BLUE}Steps 1-6${RESET} were previously complete.\n\n"

      printf "If you reboot between install steps the drive name could change as they are not always loaded in the same order.\n"
      printf "Check ${BLUE}settings.conf${RESET} again if a reboot is performed.\n\n"

      if prompt_confirm "Are you ready to continue?"; then
        printf "${GREEN}Starting Install${RESET}\n"

        load_config

        printf "${MAGENTA}Verify mounts...${RESET}\n"
        ensure_lfs_layout_and_mounts
        printf "${GREEN}Verification successful!${RESET}\n\n"
        [ -f "$LFS/lfs-ai/scripts/final" ] || die "Missing $LFS/lfs-ai/scripts/final"

            chroot "$LFS" /usr/bin/env -i              \
                HOME=/root                             \
                TERM="$TERM"                           \
                PS1='(lfs chroot) \u:\w\$ '            \
                PATH=/usr/bin:/usr/sbin:/bin:/sbin     \
                MAKEFLAGS="-j$(nproc)"                 \
                TESTSUITEFLAGS="-j$(nproc)"            \
                ADD_CFLAGS="${ADD_CFLAGS:-}"           \
                CFLAGS="${CFLAGS} ${ADD_CFLAGS:-}"     \
                CXXFLAGS="${CXXFLAGS} ${ADD_CFLAGS:-}" \
                CPPFLAGS="${CPPFLAGS} ${ADD_CFLAGS:-}" \
                DRIVE="$DRIVE"                         \
                EFI="$EFI"                             \
                SWAP="$SWAP"                           \
                MAIN="$MAIN"                           \
                /bin/bash /lfs-ai/scripts/final

            if prompt_remove "Do you want to remove log files?"; then
                printf "${GREEN}Removing logs...${RESET}\n"
                rm -rf "$LFS/logs"
            else
                printf "${GREEN}Skipping log removal.${RESET}\n"
            fi

            if prompt_remove "Do you want to remove script files?"; then
                printf "${GREEN}Removing scripts...${RESET}\n"
                rm -rf "$LFS/lfs-ai"
            else
                printf "${GREEN}Skipping script removal.${RESET}\n"
            fi

            if prompt_remove "Do you want to remove source files?"; then
                printf "${GREEN}Removing sources...${RESET}\n"
                rm -rf "$LFS/sources"
            else
                printf "${GREEN}Skipping source removal.${RESET}\n"
            fi

            [ ! -e /etc/bash.bashrc.NOUSE ] || mv /etc/bash.bashrc.NOUSE /etc/bash.bashrc

            printf "${MAGENTA}Unmounting...${RESET}\n"

            unmount_if_mounted() {
                local target="$1"

                if mountpoint -q "$target"; then
                    umount "$target" 2>/dev/null || umount -l "$target" || die "Failed to unmount $target"
                fi
            }

            unmount_if_mounted "$LFS/dev/shm"
            unmount_if_mounted "$LFS/dev/pts"
            unmount_if_mounted "$LFS/run"
            unmount_if_mounted "$LFS/proc"
            unmount_if_mounted "$LFS/sys"
            unmount_if_mounted "$LFS/dev"
            unmount_if_mounted "$LFS/boot"
            unmount_if_mounted "$LFS"

            if swapon --show=NAME 2>/dev/null | grep -Fxq "$SWAP"; then
                swapoff "$SWAP" || die "Failed to disable swap on $SWAP"
            fi

            printf "\n\n${GREEN}Success, Linux from Scratch is installed!${RESET}\n\n"
      else
        exit 1
      fi

    ;;




    :)
      called_with_args="true"
      printf "ERROR: Option -%s requires an argument.\n\n" "$OPTARG" >&2
      usage
      exit 1
    ;;




    ?)
      # Handle invalid options
      called_with_args="true"
      printf "ERROR: Invalid option: -%s\n\n" "$OPTARG" >&2
      usage
      exit 1
    ;;
  esac
done




# Script can't run without options
if [[ "$called_with_args" == "false" ]]; then
    printf "ERROR: No options were passed. See below before proceeding.\n"
    usage
    exit 1
fi
