#!/usr/bin/env bash
# LFS-AI - Download Script
# Purpose: Download the required source packages
# Safe rerun: Yes
# Copyright (c) 2026 Michael Femiak (Vercety1534)
# SPDX-License-Identifier: MIT

set -euo pipefail

umask 022

RED=$'\033[31m'
GREEN=$'\033[32m'
BLUE=$'\033[34m'
MAGENTA=$'\033[35m'
RESET=$'\033[0m'

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
base_dir="$(cd -- "$script_dir/.." && pwd)"

MAX_RETRIES=3
RETRY_DELAY=5


# Error handling
die() {
    printf '%sERROR:%s %s\n' "$RED" "$RESET" "$1" >&2
    exit 1
}


# Required inputs
require_var() {
    [ -n "${!1:-}" ] || die "Required variable $1 is not set."
}

for var in LFS; do
    require_var "$var"
done

LOG_FILE="$LFS/logs/download.log"


# Runtime prerequisites
[ -f "$base_dir/lists/wget-list" ] || die "Missing download list: $base_dir/lists/wget-list"
[ -d "$LFS/sources" ] || die "Missing sources directory: $LFS/sources"
[ -d "$LFS/logs" ] || die "Missing logs directory: $LFS/logs"


# Archive Check
has_checksum_entry() {
    local filename="$1"

    awk -v file="$filename" '
        {
            line = $0
            sub(/^[0-9a-fA-F]+[[:space:]]+\*?/, "", line)
            if (line == file) {
                found = 1
                exit
            }
        }
        END { exit(found ? 0 : 1) }
    ' "$base_dir/lists/sha256sums"
}

checksum_file() {
    local filename="$1"

    (
        cd "$LFS/sources" || exit 1
        awk -v file="$filename" '
            {
                line = $0
                sub(/^[0-9a-fA-F]+[[:space:]]+\*?/, "", line)
                if (line == file) {
                    print
                    exit
                }
            }
        ' "$base_dir/lists/sha256sums" | sha256sum -c - >/dev/null 2>&1
    )
}

get_filename_from_url() {
    local url="$1"
    printf '%s\n' "${url##*/}"
}




# Download packages
[ -f "$base_dir/lists/sha256sums" ] || die "Missing checksum file: $base_dir/lists/sha256sums"

printf '\n%sStarting downloads...%s\n' "$MAGENTA" "$RESET"
: > "$LOG_FILE"
printf 'Download started: %s\n' "$(date '+%F %T')" >> "$LOG_FILE"

# wget progress output is not fully consistent across distro versions/builds.
# For example, Fedora may be more verbose than Ubuntu or Arch.
download_failed=0
FAILED_LIST="$LFS/logs/download-failures.log"
: > "$FAILED_LIST"

while IFS= read -r url || [ -n "$url" ]; do
    case "$url" in
        ''|\#*) continue ;;
    esac

    filename="$(get_filename_from_url "$url")"

    if [ -f "$LFS/sources/$filename" ]; then
        if has_checksum_entry "$filename"; then
            if checksum_file "$filename"; then
                printf '%sOK:%s Already present and verified: %s\n' "$GREEN" "$RESET" "$filename"
                printf 'SKIPPED verified existing file %s at %s\n' \
                    "$filename" "$(date '+%F %T')" >> "$LOG_FILE"
                continue
            else
                printf '%sERROR:%s Existing file failed checksum, removing: %s\n' \
                    "$RED" "$RESET" "$filename"
                printf 'REMOVING bad existing file %s at %s\n' \
                    "$filename" "$(date '+%F %T')" >> "$LOG_FILE"
                rm -f "$LFS/sources/$filename"
            fi
        else
            printf '%sOK:%s Existing file not checksum-managed, keeping: %s\n' \
                "$GREEN" "$RESET" "$filename"
            printf 'SKIPPED unmanaged existing file %s at %s\n' \
                "$filename" "$(date '+%F %T')" >> "$LOG_FILE"
            continue
        fi
    fi

    COUNT=0
    while [ "$COUNT" -lt "$MAX_RETRIES" ]; do
        printf 'Attempt %s for %s at %s\n' \
            "$((COUNT + 1))" "$url" "$(date '+%F %T')" >> "$LOG_FILE"

        if wget -q --show-progress \
            --no-clobber \
            --continue \
            --directory-prefix="$LFS/sources" \
            --tries=1 \
            --timeout=30 \
            --dns-timeout=15 \
            --connect-timeout=15 \
            --read-timeout=30 \
            --retry-connrefused \
            "$url"
        then
            printf 'SUCCESS %s at %s\n' "$url" "$(date '+%F %T')" >> "$LOG_FILE"
            break
        fi

        COUNT=$((COUNT + 1))
        printf 'FAILED attempt %s for %s at %s\n' \
            "$COUNT" "$url" "$(date '+%F %T')" >> "$LOG_FILE"

        if [ "$COUNT" -lt "$MAX_RETRIES" ]; then
            printf '\n%sERROR:%s Failed: %s\n' "$RED" "$RESET" "$url"
            printf '%sRetrying in %s seconds...%s\n' "$MAGENTA" "$RETRY_DELAY" "$RESET"
            sleep "$RETRY_DELAY"
        else
            printf 'ABORTED after %s attempts: %s\n' \
                "$MAX_RETRIES" "$url" >> "$LOG_FILE"
            printf '%s\n' "$url" >> "$FAILED_LIST"
            download_failed=1
            break
        fi
    done
done < "$base_dir/lists/wget-list"

chown --quiet -R root:root "$LFS/sources"
printf 'Download completed: %s\n' "$(date '+%F %T')" >> "$LOG_FILE"

if [ "$download_failed" -eq 0 ]; then
    printf '%sLogging to:%s %s\n' "$BLUE" "$RESET" "$LOG_FILE"
    printf '%sDownloads completed!%s\n\n' "$GREEN" "$RESET"
else
    die "One or more downloads failed. See $FAILED_LIST and $LOG_FILE"
fi

printf 'Checksum verification started: %s\n' "$(date '+%F %T')" >> "$LOG_FILE"
printf '%sVerifying source checksums...%s\n' "$MAGENTA" "$RESET"
cd "$LFS/sources"

# Two CAcerts are not verified do to being non-versioned.
# Hashes could changed with-out notice, resulting in checksum failures.
checksum_failed=0

while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
        ''|\#*) continue ;;
    esac

    checksum="${line%% *}"
    rest="${line#"$checksum"}"
    filename="$(printf '%s' "$rest" | sed 's/^[[:space:]]*//; s/^\*//')"

    [ -f "$filename" ] || die "Missing downloaded file: $filename"

    if printf '%s\n' "$line" | sha256sum -c - >> "$LOG_FILE" 2>&1; then
        printf '%sOK:%s %s\n' "$GREEN" "$RESET" "$filename"
        printf 'CHECKSUM OK %s at %s\n' "$filename" "$(date '+%F %T')" >> "$LOG_FILE"
    else
        printf '%sERROR:%s Checksum failed: %s\n' "$RED" "$RESET" "$filename" >&2
        printf 'CHECKSUM FAILED %s at %s\n' "$filename" "$(date '+%F %T')" >> "$LOG_FILE"
        checksum_failed=1
    fi
done < "$base_dir/lists/sha256sums"

if [ "$checksum_failed" -eq 0 ]; then
    printf '%sDownload and checksum verification successful!%s\n\n' "$GREEN" "$RESET"
    printf 'Checksum verification successful: %s\n' "$(date '+%F %T')" >> "$LOG_FILE"
else
    die "One or more checksum verifications failed. See $LOG_FILE"
fi
