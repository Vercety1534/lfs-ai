#!/usr/bin/env bash
# LFS-AI - Final Script
# Purpose: Install kernel, config files, and clean up build system
# Safe rerun: Yes (Will fail if logs and/or sources were previously removed)
# Copyright (c) 2026 Michael Femiak (Vercety1534)
# SPDX-License-Identifier: MIT

set -euo pipefail

RED=$'\033[31m'
GREEN=$'\033[32m'
BLUE=$'\033[34m'
MAGENTA=$'\033[35m'
RESET=$'\033[0m'

KERNELA=6.19.11
KERNELB=7.0-rc6
LFS_VERSION=r13.0-17-systemd


# Error handling
die() {
    printf '%sERROR:%s %s\n' "$RED" "$RESET" "$1" >&2
    exit 1
}


# Log command
run_log() {
    local LOG_FILE="/logs/final.log"

    if "$@" >> "$LOG_FILE" 2>&1; then
        return 0
    else
        printf '%sERROR:%s %s failed. See %s\n' "$RED" "$RESET" "$*" "$LOG_FILE" >&2
        return 1
    fi
}

run_log_kernela() {
    local LOG_FILE="/logs/linux-$KERNELA.log"

    if "$@" >> "$LOG_FILE" 2>&1; then
        return 0
    else
        printf '%sERROR:%s %s failed. See %s\n' "$RED" "$RESET" "$*" "$LOG_FILE" >&2
        return 1
    fi
}

run_log_kernelb() {
    local LOG_FILE="/logs/linux-$KERNELB.log"

    if "$@" >> "$LOG_FILE" 2>&1; then
        return 0
    else
        printf '%sERROR:%s %s failed. See %s\n' "$RED" "$RESET" "$*" "$LOG_FILE" >&2
        return 1
    fi
}


# Pick DNS profile
prompt_dns_profile() {
    local input

    printf '%sNetwork DNS setup%s\n' "$MAGENTA" "$RESET"
    printf 'Choose how DNS should be configured for this system.\n\n'
    printf '  1) Standard DHCP DNS\n'
    printf '  2) Filtered DNS (Cloudflare Family + Quad9)\n\n'
    printf 'Selection [1]: '

    while :; do
        IFS= read -r input
        [ -n "$input" ] || input='1'

        case "$input" in
            1)
                DNS_PROFILE='default'
                export DNS_PROFILE
                return 0
                ;;
            2)
                DNS_PROFILE='filtered'
                export DNS_PROFILE
                return 0
                ;;
            *)
                printf '%sERROR:%s Enter 1 or 2.\n' "$RED" "$RESET" >&2
                printf 'Selection [1]: '
                ;;
        esac
    done
}


# Create host name
prompt_hostname() {
    local input

    printf '%sSystem hostname setup%s\n' "$MAGENTA" "$RESET"
    printf 'Enter the name this computer should use on the network.\n'
    printf 'Example: %slfs%s, %smy-pc%s, or %sworkstation1%s\n\n' \
        "$BLUE" "$RESET" "$BLUE" "$RESET" "$BLUE" "$RESET"

    while :; do
        printf 'Hostname: '
        IFS= read -r input

        case "$input" in
            '')
                printf '%sERROR:%s Hostname cannot be empty.\n' "$RED" "$RESET" >&2
                ;;
            *[!A-Za-z0-9.-]*)
                printf '%sERROR:%s Hostname may only contain letters, numbers, dots, and hyphens.\n' "$RED" "$RESET" >&2
                ;;
            -*|*.|*..*)
                printf '%sERROR:%s Invalid hostname format.\n' "$RED" "$RESET" >&2
                ;;
            *)
                HOSTNAME="$input"
                export HOSTNAME
                return 0
                ;;
        esac
    done
}


# Set console
keymap_exists() {
    local keymap_name="$1"
    local keymap_dir='/usr/share/keymaps'
    local match

    match="$(
        find "$keymap_dir" \
            \( -name "${keymap_name}.map" -o -name "${keymap_name}.map.gz" \) \
            -print -quit 2>/dev/null
    )"

    [ -n "$match" ]
}

normalize_console_keymap() {
    case "$1" in
        ru) printf '%s\n' 'ru1' ;;
        *)  printf '%s\n' "$1" ;;
    esac
}

unsupported_console_keymap() {
    case "$1" in
        apple-*|neo|neoqwertz|bone|koy|adnw|3l|fr-bepo|fr-afnor|ruwin_*UTF-8|ttwin_*UTF-8|bg_*utf8|mk-utf|lt|lv|lv-tilde|ro|ro_std)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

prompt_keymap() {
    local input
    local default_keymap='us'

    printf '%sConsole keyboard setup%s\n' "$MAGENTA" "$RESET"
    printf 'Enter the keyboard layout for the Linux console.\n'
    printf 'Examples: %sus%s, %suk%s, %sde%s, %sfr%s\n' \
        "$BLUE" "$RESET" \
        "$BLUE" "$RESET" \
        "$BLUE" "$RESET" \
        "$BLUE" "$RESET"
    printf 'See %s/usr/share/keymaps%s for available keymaps.\n' "$BLUE" "$RESET"
    printf 'Leave blank to use the default: %s%s%s\n\n' \
        "$BLUE" "$default_keymap" "$RESET"

    while :; do
        printf 'Keymap [%s]: ' "$default_keymap"
        IFS= read -r input
        [ -n "$input" ] || input="$default_keymap"

        case "$input" in
            *[!A-Za-z0-9_+-]*)
                printf '%sERROR:%s Invalid keymap format.\n' "$RED" "$RESET" >&2
                ;;
            *)
                input="$(normalize_console_keymap "$input")"

                if unsupported_console_keymap "$input"; then
                    printf '%sERROR:%s This keymap is known to be problematic on the Linux console: %s\n' \
                        "$RED" "$RESET" "$input" >&2
                    printf 'Choose a different keymap for first boot.\n' >&2
                    continue
                fi

                if keymap_exists "$input"; then
                    SYSTEM_KEYMAP="$input"
                    export SYSTEM_KEYMAP
                    return 0
                fi

                printf '%sERROR:%s Unsupported keymap: %s\n' "$RED" "$RESET" "$input" >&2
                printf 'Enter a keymap that exists under /usr/share/keymaps.\n' >&2
                ;;
        esac
    done
}

font_exists() {
    local font_name="$1"
    local font_dir='/usr/share/consolefonts'
    local match

    match="$(
        find "$font_dir" \
            \( -name "${font_name}.psf" \
            -o -name "${font_name}.psf.gz" \
            -o -name "${font_name}.psfu" \
            -o -name "${font_name}.psfu.gz" \) \
            -print -quit 2>/dev/null
    )"

    [ -n "$match" ]
}

select_console_font() {
    local locale_name="$1"

    case "$locale_name" in
        ja_*|ja_*.*|ko_*|ko_*.*|zh_*|zh_*.*)
            SYSTEM_FONT='lat0-16'
            ;;
        ru_*|ru_*.*|uk_*|uk_*.*|be_*|be_*.*|bg_*|bg_*.*|mk_*|mk_*.*|sr_*|sr_*.*)
            SYSTEM_FONT='cyr-sun16'
            ;;
        *)
            SYSTEM_FONT='Lat2-Terminus16'
            ;;
    esac

    if ! font_exists "$SYSTEM_FONT"; then
        SYSTEM_FONT='Lat2-Terminus16'
    fi

    export SYSTEM_FONT
}


# Set locale
locale_exists() {
    local locale_name="$1"
    grep -Eq "^${locale_name//./\\.}[[:space:]]" /usr/share/i18n/SUPPORTED
}

prompt_locale() {
    local input
    local default_locale='en_US.UTF-8'

    printf '\n%sSystem locale setup%s\n' "$MAGENTA" "$RESET"
    printf 'Enter a supported locale for this system.\n\n'

    printf 'Examples: %sen_US.UTF-8%s, %ses_MX.UTF-8%s, %sfr_FR.UTF-8%s\n' "$BLUE" "$RESET" "$BLUE" "$RESET" "$BLUE" "$RESET"
    printf 'Other valid examples include %sru_RU.KOI8-R%s or %sja_JP.EUC-JP%s.\n' "$BLUE" "$RESET" "$BLUE" "$RESET"
    printf 'See %s/usr/share/i18n/SUPPORTED%s for all possible values\n\n' "$BLUE" "$RESET"
    printf 'Leave blank to use the default: %s%s%s\n\n' "$BLUE" "$default_locale" "$RESET"

    while :; do
        printf 'Locale [%s]: ' "$default_locale"
        IFS= read -r input
        [ -n "$input" ] || input="$default_locale"

        if locale_exists "$input"; then
            SYSTEM_LOCALE="$input"
            export SYSTEM_LOCALE
            return 0
        fi

        printf '%sERROR:%s Unsupported locale: %s\n' "$RED" "$RESET" "$input" >&2
        printf 'Enter a locale exactly as listed in the supported locale file.\n' >&2
    done
}

generate_locale() {
    local locale_name="$1"
    local locale_line output_name input_name charmap

    locale_line="$(grep -E "^${locale_name//./\\.}[[:space:]]" /usr/share/i18n/SUPPORTED | head -n 1)"
    [ -n "$locale_line" ] || die "Could not find locale definition for $locale_name"

    output_name="${locale_line%%[[:space:]]*}"
    charmap="${locale_line##*[[:space:]]}"

    case "$output_name" in
        *@*)
            if [[ "$output_name" == *.*@* ]]; then
                input_name="${output_name%%.*}@${output_name#*@}"
            else
                input_name="$output_name"
            fi
            ;;
        *.*)
            input_name="${output_name%%.*}"
            ;;
        *)
            input_name="$output_name"
            ;;
    esac

    run_log localedef --force -i C -f UTF-8 C.UTF-8
    run_log localedef --force -i en_US -f ISO-8859-1 en_US
    run_log localedef --force -i en_US -f UTF-8 en_US.UTF-8
    run_log localedef --force -i "$input_name" -f "$charmap" "$output_name"
}




# Post install clean-up
printf '\n%sCleaning up temp files...%s\n' "$MAGENTA" "$RESET"
rm -rf /tmp/* /tmp/.[!.]* /tmp/..?* 2>/dev/null || true

while IFS= read -r path; do
    run_log rm -rf "$path"
done < <(find /usr -depth -name "$(uname -m)-lfs-linux-gnu*")

if id tester &>/dev/null; then
    run_log userdel -fr tester
fi

printf '%sClean-up successful!%s\n\n' "$GREEN" "$RESET"


# Gen fstab
printf '%sCreating fstab...%s\n' "$MAGENTA" "$RESET"
EFIUUID="$(blkid -s UUID -o value "$EFI")"
SWAPUUID="$(blkid -s UUID -o value "$SWAP")"
MAINUUID="$(blkid -s UUID -o value "$MAIN")"

[ -n "$EFIUUID" ] || die 'Missing EFI UUID'
[ -n "$SWAPUUID" ] || die 'Missing SWAP UUID'
[ -n "$MAINUUID" ] || die 'Missing MAIN UUID'

cat > /etc/fstab << EOF
# <file system>                         <mount point>  <type>       <options>         <dump>  <pass>
UUID=$EFIUUID                              /boot       vfat        defaults,umask=0077    0 2
UUID=$SWAPUUID   swap        swap        defaults               0 0
UUID=$MAINUUID   /           ext4        defaults,relatime      0 1
EOF
printf '%sCreation successful!%s\n\n' "$GREEN" "$RESET"


# Network Configuration
printf '%sConfiguring network...%s\n' "$MAGENTA" "$RESET"
prompt_dns_profile

case "$DNS_PROFILE" in
    default)
        cat > /etc/systemd/network/20-wired.network << "EOF"
[Match]
Name=en* eth*

[Link]
RequiredForOnline=routable

[Network]
DHCP=yes
EOF
        ;;
    filtered)
        cat > /etc/systemd/network/20-wired.network << "EOF"
[Match]
Name=en* eth*

[Link]
RequiredForOnline=routable

[Network]
DHCP=yes
DNS=1.1.1.2
DNS=1.0.0.2
DNS=9.9.9.9
EOF
        ;;
    *)
        die "Unsupported DNS profile: $DNS_PROFILE"
        ;;
esac

ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf


# Configuring the system hostname
prompt_hostname
printf '%s\n' "$HOSTNAME" > /etc/hostname


cat > /etc/hosts << EOF
# Begin /etc/hosts

127.0.0.1  localhost
127.0.1.1  $HOSTNAME
::1        localhost ip6-localhost ip6-loopback
ff02::1    ip6-allnodes
ff02::2    ip6-allrouters

# End /etc/hosts
EOF

printf '%sConfiguration successful!%s\n\n' "$GREEN" "$RESET"


# Configuring the Linux Console
printf '%sConfiguring console...%s\n' "$MAGENTA" "$RESET"
prompt_keymap
prompt_locale
generate_locale "$SYSTEM_LOCALE"
select_console_font "$SYSTEM_LOCALE"

cat > /etc/vconsole.conf << EOF
KEYMAP=$SYSTEM_KEYMAP
FONT=$SYSTEM_FONT
EOF

cat > /etc/locale.conf << EOF
LANG=$SYSTEM_LOCALE
EOF


# Creating the /etc/inputrc File
cat > /etc/inputrc << "EOF"
# Begin /etc/inputrc

# Allow the command prompt to wrap to the next line
set horizontal-scroll-mode Off

# Enable 8-bit input
set meta-flag On
set input-meta On

# Turns off 8th bit stripping
set convert-meta Off

# Keep the 8th bit for display
set output-meta On

# none, visible or audible
set bell-style none

# All of the following map the escape sequence of the value
# contained in the 1st argument to the readline specific functions
"\eOd": backward-word
"\eOc": forward-word

# for linux console
"\e[1~": beginning-of-line
"\e[4~": end-of-line
"\e[5~": beginning-of-history
"\e[6~": end-of-history
"\e[3~": delete-char
"\e[2~": quoted-insert

# for xterm
"\eOH": beginning-of-line
"\eOF": end-of-line

# for Konsole
"\e[H": beginning-of-line
"\e[F": end-of-line

# completion/readline behavior
set show-all-if-ambiguous on
set visible-stats on

# End /etc/inputrc
EOF


# Creating the /etc/shells File
cat > /etc/shells << "EOF"
# Begin /etc/shells

/bin/sh
/bin/bash

# End /etc/shells
EOF


# Working with Core Dumps
mkdir -p /etc/systemd/coredump.conf.d

cat > /etc/systemd/coredump.conf.d/maxuse.conf << EOF
[Coredump]
MaxUse=5G
EOF
printf '%sConfiguration successful!%s\n\n' "$GREEN" "$RESET"


# Install linux-$KERNELA
printf '%sInstalling Kernel %s...%s\n' "$MAGENTA" "$KERNELA" "$RESET"
run_log_kernela cp -v "/sources/linux-$KERNELA.tar.xz" "/usr/src/linux-$KERNELA.tar.xz"
cd /usr/src

run_log_kernela rm -rf "/usr/src/linux-$KERNELA"
run_log_kernela tar -xvf "linux-$KERNELA.tar.xz"
run_log_kernela rm -rfv "linux-$KERNELA.tar.xz"
cd "/usr/src/linux-$KERNELA"

run_log_kernela make clean
run_log_kernela make mrproper

run_log_kernela cp -vf /lfs-ai/lists/config .config
run_log_kernela make olddefconfig

run_log_kernela make
run_log_kernela make headers
run_log_kernela make headers_install
run_log_kernela make modules
run_log_kernela make modules_install

run_log_kernela cp -vf arch/x86/boot/bzImage "/boot/vmlinuz-$KERNELA-lfs"
run_log_kernela cp -vf System.map "/boot/System.map-$KERNELA"
run_log_kernela cp -vf .config "/boot/config-$KERNELA"

run_log_kernela rm -rf "/usr/share/doc/linux-$KERNELA"
run_log_kernela cp -vr Documentation -T "/usr/share/doc/linux-$KERNELA"

run_log_kernela chown -R 0:0 "/usr/src/linux-$KERNELA"
printf '%sInstall successful!%s\n\n' "$GREEN" "$RESET"


# Install linux-$KERNELB
printf '%sInstalling Kernel %s...%s\n' "$MAGENTA" "$KERNELB" "$RESET"
run_log_kernelb cp -v "/sources/linux-$KERNELB.tar.gz" "/usr/src/linux-$KERNELB.tar.gz"
cd /usr/src

run_log_kernelb rm -rf "/usr/src/linux-$KERNELB"
run_log_kernelb tar -xvf "linux-$KERNELB.tar.gz"
run_log_kernelb rm -rfv "linux-$KERNELB.tar.gz"
cd "/usr/src/linux-$KERNELB"

run_log_kernelb make clean
run_log_kernelb make mrproper

run_log_kernelb cp -vf /lfs-ai/lists/config .config
run_log_kernelb make olddefconfig

run_log_kernelb make
run_log_kernelb make headers
run_log_kernelb make headers_install
run_log_kernelb make modules
run_log_kernelb make modules_install

run_log_kernelb cp -vf arch/x86/boot/bzImage "/boot/vmlinuz-$KERNELB-lfs"
run_log_kernelb cp -vf System.map "/boot/System.map-$KERNELB"
run_log_kernelb cp -vf .config "/boot/config-$KERNELB"

run_log_kernelb rm -rf "/usr/share/doc/linux-$KERNELB"
run_log_kernelb cp -vr Documentation -T "/usr/share/doc/linux-$KERNELB"

run_log_kernelb chown -R 0:0 "/usr/src/linux-$KERNELB"
printf '%sInstall successful!%s\n\n' "$GREEN" "$RESET"


# Configuring Linux Module Load Order
install -m755 -d /etc/modprobe.d
cat > /etc/modprobe.d/usb.conf << "EOF"
# Begin /etc/modprobe.d/usb.conf

install ohci_hcd /sbin/modprobe ehci_hcd ; /sbin/modprobe -i ohci_hcd ; true
install uhci_hcd /sbin/modprobe ehci_hcd ; /sbin/modprobe -i uhci_hcd ; true

# End /etc/modprobe.d/usb.conf
EOF


# Using Limine to Set Up the Boot Process
printf '%sConfiguring limine...%s\n' "$MAGENTA" "$RESET"
mounted_efivars=0
if ! mountpoint -q /sys/firmware/efi/efivars; then
    run_log mount -t efivarfs efivarfs /sys/firmware/efi/efivars
    mounted_efivars=1
fi

get_partition_number() {
    local dev="$1"

    case "$dev" in
        /dev/nvme*n*p[0-9]*|/dev/mmcblk*p[0-9]*)
            printf '%s\n' "${dev##*p}"
            ;;
        /dev/sd[a-z][0-9]*|/dev/vd[a-z][0-9]*|/dev/xvd[a-z][0-9]*)
            printf '%s\n' "${dev##*[!0-9]}"
            ;;
        *)
            lsblk -no PARTN "$dev" 2>/dev/null || true
            ;;
    esac
}

BOOT_LABEL="LFS Limine Boot Loader"
EFI_REL_PATH='\EFI\LFS\LIMINEX64.EFI'
EFI_PART_NUM="$(get_partition_number "$EFI")"

[ -n "$EFI_PART_NUM" ] || die "Could not determine EFI partition number for $EFI"

existing_ids="$(
    efibootmgr | awk -v label="$BOOT_LABEL" '
        index($0, label) {
            boot=$1
            sub(/\*.*/, "", boot)
            if (boot ~ /^Boot[0-9A-Fa-f]{4}$/) {
                print substr(boot, 5)
            }
        }
    '
)"

if [ -n "$existing_ids" ]; then
    printf '%sINFO:%s Removing existing EFI boot entry/entries for %s.\n' "$BLUE" "$RESET" "$BOOT_LABEL"
    while IFS= read -r bootnum; do
        [ -n "$bootnum" ] || continue
        run_log efibootmgr --delete-bootnum --bootnum "$bootnum" || true
    done <<< "$existing_ids"
fi

printf '%sINFO:%s Creating EFI boot entry %s.\n' "$BLUE" "$RESET" "$BOOT_LABEL"
run_log efibootmgr                      \
      --create                          \
      --disk "$DRIVE"                   \
      --part "$EFI_PART_NUM"            \
      --label "$BOOT_LABEL"             \
      --loader "$EFI_REL_PATH"          \
      --unicode

ROOTPARTUUID="$(blkid -s PARTUUID -o value "$MAIN")"
[ -n "$ROOTPARTUUID" ] || die "Could not determine PARTUUID for $MAIN"

cat > /boot/limine.conf << EOF
timeout: 5
remember_last_entry: yes

/+LFS
  //vmlinuz-$KERNELA-lfs
    protocol: linux
    kernel_path: boot():/vmlinuz-$KERNELA-lfs
    cmdline: root=PARTUUID=$ROOTPARTUUID rw quiet loglevel=3 audit=0
  //vmlinuz-$KERNELB-lfs
    protocol: linux
    kernel_path: boot():/vmlinuz-$KERNELB-lfs
    cmdline: root=PARTUUID=$ROOTPARTUUID rw quiet loglevel=3 audit=0
EOF
printf '%sConfiguration successful!%s\n\n' "$GREEN" "$RESET"


# The End
printf '%sFinal configuration...%s\n' "$MAGENTA" "$RESET"
printf '%s\n' "$LFS_VERSION" > /etc/lfs-release

cat > /etc/lsb-release << EOF
DISTRIB_ID="Linux From Scratch"
DISTRIB_RELEASE="$LFS_VERSION"
DISTRIB_CODENAME="LFS-AI"
DISTRIB_DESCRIPTION="Linux From Scratch"
EOF

cat > /etc/os-release << EOF
NAME="Linux From Scratch"
VERSION="$LFS_VERSION"
ID=lfs
PRETTY_NAME="Linux From Scratch $LFS_VERSION"
VERSION_CODENAME="LFS-AI"
HOME_URL="https://www.linuxfromscratch.org/lfs/"
RELEASE_TYPE="development"
EOF

cat > /etc/profile << "EOF"
# Begin /etc/profile

# System-wide environment variables and startup programs.
# Bash-specific aliases and functions belong in /etc/bashrc.

export PATH=/usr/bin

if [ ! -L /bin ]; then
    PATH=$PATH:/bin
fi

if [ "$(id -u)" -eq 0 ]; then
    PATH=$PATH:/usr/sbin
    if [ ! -L /sbin ]; then
        PATH=$PATH:/sbin
    fi
    unset HISTFILE
fi

export PATH
export HISTSIZE=1000
export HISTIGNORE='&:[bf]g:exit'

export XDG_DATA_DIRS="${XDG_DATA_DIRS:-/usr/share}"
export XDG_CONFIG_DIRS="${XDG_CONFIG_DIRS:-/etc/xdg}"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp/xdg-$USER}"

for script in /etc/profile.d/*.sh; do
    [ -r "$script" ] && . "$script"
done
unset script

# End /etc/profile
EOF

install --directory --mode=0755 --owner=root --group=root /etc/profile.d

cat > /etc/profile.d/dircolors.sh << "EOF"
# Setup for /bin/ls and /bin/grep to support color, the alias is in /etc/bashrc.
if [ -f "/etc/dircolors" ] ; then
        eval $(dircolors -b /etc/dircolors)
fi

if [ -f "$HOME/.dircolors" ] ; then
        eval $(dircolors -b $HOME/.dircolors)
fi
EOF

cat > /etc/profile.d/extrapaths.sh << "EOF"
case ":${PKG_CONFIG_PATH:-}:" in
    *:/usr/local/lib/pkgconfig:*) ;;
    *) [ -d /usr/local/lib/pkgconfig ] && PKG_CONFIG_PATH="${PKG_CONFIG_PATH:+$PKG_CONFIG_PATH:}/usr/local/lib/pkgconfig" ;;
esac
export PKG_CONFIG_PATH

case ":$PATH:" in
    *:/usr/local/bin:*) ;;
    *) [ -d /usr/local/bin ] && PATH="/usr/local/bin:$PATH" ;;
esac

if [ "$(id -u)" -eq 0 ]; then
    case ":$PATH:" in
        *:/usr/local/sbin:*) ;;
        *) [ -d /usr/local/sbin ] && PATH="/usr/local/sbin:$PATH" ;;
    esac
fi

case ":${XDG_DATA_DIRS:-}:" in
    *:/usr/local/share:*) ;;
    *) [ -d /usr/local/share ] && XDG_DATA_DIRS="/usr/local/share${XDG_DATA_DIRS:+:$XDG_DATA_DIRS}" ;;
esac
export XDG_DATA_DIRS

case ":${INFOPATH:-}:" in
    *:/usr/share/info:*) ;;
    *) INFOPATH="${INFOPATH:+$INFOPATH:}/usr/share/info" ;;
esac
export INFOPATH

export PATH
EOF

cat > /etc/profile.d/readline.sh << "EOF"
# Set up the INPUTRC environment variable.
if [ -z "$INPUTRC" -a ! -f "$HOME/.inputrc" ] ; then
        INPUTRC=/etc/inputrc
fi
export INPUTRC
EOF

cat > /etc/profile.d/umask.sh << "EOF"
# By default, the umask should be set.
if [ "$(id -gn)" = "$(id -un)" ] && [ "$(id -u)" -gt 99 ]; then
  umask 002
else
  umask 022
fi
EOF

cat > /etc/profile.d/i18n.sh << "EOF"
. /etc/locale.conf
export LANG
EOF

cat > /etc/bashrc << "EOF"
# Begin /etc/bashrc

# System wide aliases and functions.

# System wide environment variables and startup programs should go into
# /etc/profile.  Personal environment variables and startup programs
# should go into ~/.bash_profile.  Personal aliases and functions should
# go into ~/.bashrc

# Provides colored /bin/ls and /bin/grep commands.

if [ -f "/etc/dircolors" ] ; then
        eval $(dircolors -b /etc/dircolors)
fi

if [ -f "$HOME/.dircolors" ] ; then
        eval $(dircolors -b $HOME/.dircolors)
fi

alias ls='ls --color=auto'
alias grep='grep --color=auto'

# Provides prompt for interactive shells, specifically shells started
# in the X environment. [Review the LFS archive thread titled
# PS1 Environment Variable for a great case study behind this script
# addendum.]

NORMAL="\[\e[0m\]"
RED="\[\e[1;31m\]"
PURPLE="\[\e[1;35m\]"
BLUE="\[\e[1;34m\]"
if [[ $EUID == 0 ]] ; then
  PS1="$RED\u $BLUE\w $NORMAL\$ "
else
  PS1="$PURPLE\u $BLUE\w $NORMAL\$ "
fi

unset RED PURPLE BLUE NORMAL

# Use bash-completion, if available, and avoid double-sourcing
[[ $PS1 &&
  ! ${BASH_COMPLETION_VERSINFO:-} &&
  -f /usr/share/bash-completion/bash_completion ]] &&
    . /usr/share/bash-completion/bash_completion

# GnuPG wants this or it'll fail with pinentry-curses under some
# circumstances (for example signing a Git commit)
# Note that tty -s will "succeed" in LFS chroot environment so we cannot
# use -s instead of redirecting to /dev/null.
tty >/dev/null 2>&1 && export GPG_TTY="$(tty)"

# End /etc/bashrc
EOF

cat > /root/.bash_profile << "EOF"
# Begin ~/.bash_profile

if [ -f "$HOME/.bashrc" ] ; then
  . "$HOME/.bashrc"
fi

if [ -d "$HOME/bin" ] ; then
  case ":$PATH:" in
    *:"$HOME/bin":*) ;;
    *) PATH="$HOME/bin:$PATH" ;;
  esac
  export PATH
fi

# End ~/.bash_profile
EOF

cat > /root/.profile << "EOF"
# Begin ~/.profile

if [ -d "$HOME/bin" ] ; then
  case ":$PATH:" in
    *:"$HOME/bin":*) ;;
    *) PATH="$HOME/bin:$PATH" ;;
  esac
  export PATH
fi

# End ~/.profile
EOF

cat > /root/.bashrc << "EOF"
# Begin ~/.bashrc

# Personal aliases and functions.

# Personal environment variables and startup programs should go in
# ~/.bash_profile.  System wide environment variables and startup
# programs are in /etc/profile.  System wide aliases and functions are
# in /etc/bashrc.

if [ -f "/etc/bashrc" ] ; then
  . /etc/bashrc
fi

# Set up user specific i18n variables
#export LANG=<ll>_<CC>.<charmap><@modifiers>

# End ~/.bashrc
EOF

cat > /root/.bash_logout << "EOF"
# Begin ~/.bash_logout

# Personal items to perform on logout.

# End ~/.bash_logout
EOF

cat > /etc/issue << "EOF"
Welcome to Linux From Scratch (LFS-AI)!

EOF
printf '%sConfiguration successful!%s\n\n' "$GREEN" "$RESET"

# Make Skel files and services
printf '%sCreating skeleton files and enabling network services...%s\n' "$MAGENTA" "$RESET"
pushd /usr/share/info > /dev/null
run_log rm -fv dir
for f in *; do
    install-info "$f" dir 2>/dev/null || true
done
popd > /dev/null

dircolors -p > /etc/dircolors

run_log mkdir -pv /root/Desktop
run_log mkdir -pv /root/Documents
run_log mkdir -pv /root/Downloads
run_log mkdir -pv /root/Music
run_log mkdir -pv /root/Pictures
run_log mkdir -pv /root/Public
run_log mkdir -pv /root/Templates
run_log mkdir -pv /root/Videos
run_log mkdir -pv /etc/skel/
run_log mkdir -pv /etc/skel/Desktop
run_log mkdir -pv /etc/skel/Documents
run_log mkdir -pv /etc/skel/Downloads
run_log mkdir -pv /etc/skel/Music
run_log mkdir -pv /etc/skel/Pictures
run_log mkdir -pv /etc/skel/Public
run_log mkdir -pv /etc/skel/Templates
run_log mkdir -pv /etc/skel/Videos
run_log cp -v /root/.profile /etc/skel/.profile
run_log cp -v /root/.bashrc /etc/skel/.bashrc
dircolors -p > /etc/skel/.dircolors

[ -f /lfs-ai/scripts/lfs-ai-verify ] || die 'Missing /lfs-ai/scripts/lfs-ai-verify'
run_log install -m755 -o root -g root /lfs-ai/scripts/lfs-ai-verify /usr/sbin/lfs-ai-verify

run_log systemctl enable systemd-resolved
run_log systemctl enable systemd-networkd

if [ "$mounted_efivars" -eq 1 ]; then
    run_log umount /sys/firmware/efi/efivars
fi
printf '%sSuccessful!%s\n\n' "$GREEN" "$RESET"

