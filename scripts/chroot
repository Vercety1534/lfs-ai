#!/usr/bin/env bash
# LFS-AI - Chroot Script
# Purpose: Prepare the chroot environment
# Safe rerun: Yes
# Copyright (c) 2026 Michael Femiak (Vercety1534)
# SPDX-License-Identifier: MIT

set -e

umask 022

RED='\033[31m'
GREEN='\033[32m'
BLUE='\033[34m'
MAGENTA='\033[35m'
RESET='\033[0m'

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
base_dir="$(cd -- "$script_dir/.." && pwd)"
CONFIG_FILE="$base_dir/settings.conf"




# Validate settings
die() {
    printf "${RED}ERROR:${RESET} %s\n" "$1" >&2
    exit 1
}

validate_placeholder() {
    local name="$1"
    local value="$2"

    case "$value" in
        REPLACE_ME|/dev/REPLACE_ME)
            die "$name is still set to a placeholder value."
            ;;
    esac
}

validate_drive_name() {
    local value="$1"

    validate_placeholder "DRIVE" "$value"

    case "$value" in
        /dev/sd[a-z]|/dev/vd[a-z]|/dev/xvd[a-z]|/dev/nvme[0-9]n[0-9]|/dev/mmcblk[0-9])
            ;;
        *)
            die "DRIVE must be a whole disk like /dev/sda, /dev/vda, /dev/nvme0n1, or /dev/mmcblk0. Got: $value"
            ;;
    esac

    case "$value" in
        /dev/sd[a-z][0-9]|/dev/vd[a-z][0-9]|/dev/xvd[a-z][0-9]|/dev/nvme[0-9]n[0-9]p[0-9]|/dev/mmcblk[0-9]p[0-9])
            die "DRIVE must be a whole disk, not a partition. Got: $value"
            ;;
    esac

    [ -b "$value" ] || die "DRIVE is not a real block device: $value"
}

validate_nonempty_path() {
    local name="$1"
    local value="$2"

    [ -n "$value" ] || die "$name is empty."

    case "$value" in
        /*)
            ;;
        *)
            die "$name must be an absolute path. Got: $value"
            ;;
    esac
}

derive_partitions() {
    case "$DRIVE" in
        /dev/nvme*|/dev/mmcblk*)
            EFI="${DRIVE}p1"
            SWAP="${DRIVE}p2"
            MAIN="${DRIVE}p3"
            ;;
        /dev/sd*|/dev/vd*|/dev/xvd*)
            EFI="${DRIVE}1"
            SWAP="${DRIVE}2"
            MAIN="${DRIVE}3"
            ;;
        *)
            die "Unsupported DRIVE format: $DRIVE"
            ;;
    esac
}

validate_make_jobs() {
    local value="$1"
    local jobs

    [ -n "$value" ] || die "MAKE_JOBS is empty."

    case "$value" in
        -j[0-9]*)
            jobs="${value#-j}"
            ;;
        *)
            die "MAKE_JOBS must look like -j4 or -j16. Got: $value"
            ;;
    esac

    case "$jobs" in
        *[!0-9]*|"")
            die "MAKE_JOBS must contain a positive integer after -j. Got: $value"
            ;;
    esac

    [ "$jobs" -ge 1 ] || die "MAKE_JOBS must be at least -j1. Got: $value"
}

validate_config() {
    validate_drive_name "$DRIVE"

    validate_nonempty_path "LFS" "$LFS"
    
    validate_make_jobs "$MAKE_JOBS"

    [ "$LFS" != "/" ] || die "LFS cannot be /"
    [ "$LFS" != "/boot" ] || die "LFS cannot be /boot"
    [ "$LFS" != "/home" ] || die "LFS cannot be /home"
    [ "$LFS" != "/mnt" ] || die "LFS cannot be /mnt"
    [ "$LFS" != "/root" ] || die "LFS cannot be /root"

    derive_partitions

    [ "$EFI" != "$SWAP" ] || die "EFI and SWAP must not be the same partition."
    [ "$EFI" != "$MAIN" ] || die "EFI and MAIN must not be the same partition."
    [ "$SWAP" != "$MAIN" ] || die "SWAP and MAIN must not be the same partition."
}

load_config() {
    [ -f "$CONFIG_FILE" ] || die "Config file not found at $CONFIG_FILE"

    source "$CONFIG_FILE"

    validate_config
    printf "Configuration loaded from ${BLUE}%s${RESET}\n\n" "$CONFIG_FILE"
}




# Validate mountpoints
ensure_mount_source() {
    local source="$1"
    local target="$2"
    shift 2

    if mountpoint -q "$target"; then
        if findmnt -nr -o SOURCE --target "$target" | grep -qx "$source"; then
            printf "${GREEN}OK:${RESET}    %s is mounted on %s.\n" "$source" "$target"
        else
            die "$target is already mounted, but not from $source"
        fi
    else
        "$@" || die "Failed to mount $source on $target"
    fi
}

ensure_swap() {
    [ -b "$SWAP" ] || die "SWAP partition does not exist: $SWAP"

    if swapon --noheadings --show=NAME 2>/dev/null | grep -Fxq "$SWAP"; then
        printf "${GREEN}OK:${RESET}    %s swap is active.\n" "$SWAP"
    else
        swapon "$SWAP" || die "Failed to activate swap on $SWAP"
        printf "${GREEN}OK:${RESET}    %s swap activated.\n" "$SWAP"
    fi
}

ensure_bind_mount() {
    local source="$1"
    local target="$2"
    local actual_source
    shift 2

    if mountpoint -q "$target"; then
        actual_source="$(findmnt -nr -o SOURCE --target "$target" 2>/dev/null || true)"
        case "$actual_source" in
            "$source"|"$source"[*])
                printf "${GREEN}OK:${RESET}    %s is bind-mounted on %s.\n" "$source" "$target"
                ;;
            *)
                printf "${GREEN}OK:${RESET}    %s is already mounted on %s.\n" "$actual_source" "$target"
                ;;
        esac
    else
        "$@" || die "Failed to bind-mount $source on $target"
    fi
}

ensure_mount_fstype() {
    local target="$1"
    local fstype="$2"
    shift 2

    if mountpoint -q "$target"; then
        if findmnt -nr -o FSTYPE --target "$target" | grep -qx "$fstype"; then
            printf "${GREEN}OK:${RESET}    %s is mounted as %s.\n" "$target" "$fstype"
        else
            die "$target is already mounted, but not as $fstype"
        fi
    else
        "$@" || die "Failed to mount $target as $fstype"
    fi
}




# Load settings.conf
load_config

[ -d "$LFS" ] || mkdir -p "$LFS"
[ -d "$LFS/boot" ] || mkdir -p "$LFS/boot"

# Verify Mounts
printf "\n${MAGENTA}Verify mounts...${RESET}\n"
[ -b "$EFI" ]  || die "EFI partition does not exist: $EFI"
[ -b "$SWAP" ] || die "SWAP partition does not exist: $SWAP"
[ -b "$MAIN" ] || die "MAIN partition does not exist: $MAIN"

ensure_mount_source "$MAIN" "$LFS"      mount "$MAIN" "$LFS"
ensure_mount_source "$EFI"  "$LFS/boot" mount "$EFI" "$LFS/boot"
ensure_swap
printf "${GREEN}Verification successful!${RESET}\n"




# Copy scripts for chroot
printf "\n${MAGENTA}Copying scripts...${RESET}\n"
rm -rf "$LFS/lfs-ai"
cp -a "$base_dir" "$LFS/lfs-ai"
chown --quiet -R root:root "$LFS/lfs-ai"
printf "${GREEN}Copy successful!${RESET}\n"

# Fix permissions
printf "\n${MAGENTA}Fixing permissions...${RESET}\n"

for path in "$LFS/usr" "$LFS/var" "$LFS/etc" "$LFS/logs" "$LFS/tools"; do
    [ -e "$path" ] || continue
    chown --quiet --from=lfs -R root:root "$path"
done

case "$(uname -m)" in
  x86_64)
    if [ -e "$LFS/lib64" ]; then
        chown --quiet --from=lfs -R root:root "$LFS/lib64"
    fi
    ;;
esac

printf "${GREEN}Permissions fixed!${RESET}\n"




# Prepare virtual file system
printf "\n${MAGENTA}Preparing virtual file system...${RESET}\n"

mkdir -p "$LFS"/{dev,dev/pts,proc,sys,run}

ensure_bind_mount "/dev" "$LFS/dev" mount --bind /dev "$LFS/dev"
ensure_mount_fstype "$LFS/dev/pts" "devpts" mount -t devpts -o gid=5,mode=0620 devpts "$LFS/dev/pts"
ensure_mount_fstype "$LFS/proc" "proc" mount -t proc proc "$LFS/proc"
ensure_mount_fstype "$LFS/sys" "sysfs" mount -t sysfs sysfs "$LFS/sys"
ensure_mount_fstype "$LFS/run" "tmpfs" mount -t tmpfs tmpfs "$LFS/run"

mkdir -p "$LFS/dev/shm"
if mountpoint -q "$LFS/dev/shm"; then
    printf "${GREEN}OK:${RESET}    %s is mounted.\n" "$LFS/dev/shm"
else
    mount -t tmpfs -o nosuid,nodev tmpfs "$LFS/dev/shm" || die "Failed to mount $LFS/dev/shm"
fi

printf "${GREEN}File system prepared!${RESET}\n"




# Enter chroot and run install scripts
[ -f "$LFS/lfs-ai/scripts/toolchain-chroot" ] || \
    die "Missing chroot entry script: $LFS/lfs-ai/scripts/toolchain-chroot"

[ -x "$LFS/usr/bin/env" ] || die "Missing $LFS/usr/bin/env"

printf "\n${MAGENTA}Entering chroot...${RESET}\n"
chroot "$LFS" /usr/bin/env -i              \
    HOME=/root                             \
    TERM="$TERM"                           \
    PS1='(lfs chroot) \u:\w\$ '            \
    PATH=/usr/bin:/usr/sbin:/bin:/sbin     \
    MAKEFLAGS="$MAKE_JOBS"                 \
    TESTSUITEFLAGS="$MAKE_JOBS"            \
    /bin/bash ./lfs-ai/scripts/toolchain-chroot
