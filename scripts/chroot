#!/usr/bin/env bash
# LFS-AI - Chroot Script
# Purpose: Verify chroot readiness, copy scripts, and enter chroot
# Safe rerun: Yes
# Copyright (c) 2026 Michael Femiak (Vercety1534)
# SPDX-License-Identifier: MIT

set -euo pipefail

umask 022

RED=$'\033[31m'
GREEN=$'\033[32m'
BLUE=$'\033[34m'
MAGENTA=$'\033[35m'
RESET=$'\033[0m'

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
base_dir="$(cd -- "$script_dir/.." && pwd)"


# Error handling
die() {
    printf '%sERROR:%s %s\n' "$RED" "$RESET" "$1" >&2
    exit 1
}


# Required inputs
require_var() {
    [ -n "${!1:-}" ] || die "Required variable $1 is not set."
}

for var in LFS MAKE_JOBS; do
    require_var "$var"
done


# Verify virtual file system mounts
require_bind_mount() {
    local source="$1"
    local target="$2"
    local actual_source

    mountpoint -q "$target" || \
        die "$target is not mounted. Run ./install -c or the normal install flow first."

    actual_source="$(findmnt -nr -o SOURCE --target "$target" 2>/dev/null || true)"

    case "$actual_source" in
        "$source"|"$source"[[]*)
            printf '%sOK:%s %s is bind-mounted on %s.\n' \
                "$GREEN" "$RESET" "$source" "$target"
            ;;
        *)
            die "$target is mounted from ${actual_source:-an unknown source} instead of $source"
            ;;
    esac
}

require_mount_fstype() {
    local target="$1"
    local fstype="$2"
    local actual_fstype

    mountpoint -q "$target" || \
        die "$target is not mounted. Run ./install -c or the normal install flow first."

    actual_fstype="$(findmnt -nr -o FSTYPE --target "$target" 2>/dev/null || true)"

    [ "$actual_fstype" = "$fstype" ] || \
        die "$target is mounted as ${actual_fstype:-unknown}, not $fstype"

    printf '%sOK:%s    %s is mounted as %s.\n' \
        "$GREEN" "$RESET" "$target" "$fstype"
}

require_dev_shm_ready() {
    local shm_target
    local shm_path

    if mountpoint -q "$LFS/dev/shm"; then
        if findmnt -nr -o FSTYPE --target "$LFS/dev/shm" | grep -qx 'tmpfs'; then
            printf '%sOK:%s    %s is mounted as tmpfs.\n' \
                "$GREEN" "$RESET" "$LFS/dev/shm"
            return 0
        fi

        die "$LFS/dev/shm is mounted, but not as tmpfs"
    fi

    if [ -h "$LFS/dev/shm" ]; then
        shm_target="$(readlink "$LFS/dev/shm")"

        case "$shm_target" in
            /*) shm_path="$LFS$shm_target" ;;
            *)  shm_path="$(dirname "$LFS/dev/shm")/$shm_target" ;;
        esac

        [ -d "$shm_path" ] || \
            die "$LFS/dev/shm points to $shm_path, but that directory does not exist"

        [ "$(stat -c '%a' "$shm_path")" = "1777" ] || \
            die "$shm_path exists, but permissions are not 1777"

        printf '%sOK:%s    %s is a symlink and its target exists with mode 1777.\n' \
            "$GREEN" "$RESET" "$LFS/dev/shm"
        return 0
    fi

    die "$LFS/dev/shm is neither a tmpfs mount nor a valid symlink target"
}




# Verify virtual file system
printf '\n%sVerifying virtual file system...%s\n' "$MAGENTA" "$RESET"

require_bind_mount "/dev" "$LFS/dev"
require_mount_fstype "$LFS/dev/pts" "devpts"
require_mount_fstype "$LFS/proc" "proc"
require_mount_fstype "$LFS/sys" "sysfs"
require_mount_fstype "$LFS/run" "tmpfs"
require_dev_shm_ready

printf '%sVirtual file system verified!%s\n' "$GREEN" "$RESET"


# Copy scripts for chroot
printf '\n%sCopying scripts...%s\n' "$MAGENTA" "$RESET"
rm -rf "$LFS/lfs-ai"
cp -a "$base_dir" "$LFS/lfs-ai"
chown --quiet -R root:root "$LFS/lfs-ai"
printf '%sCopy successful!%s\n' "$GREEN" "$RESET"


# Fix permissions
printf '\n%sFixing permissions...%s\n' "$MAGENTA" "$RESET"

for path in "$LFS/usr" "$LFS/var" "$LFS/etc" "$LFS/logs" "$LFS/tools"; do
    [ -e "$path" ] || continue
    chown --quiet --from=lfs -R root:root "$path"
done

case "$(uname -m)" in
    x86_64)
        if [ -e "$LFS/lib64" ]; then
            chown --quiet --from=lfs -R root:root "$LFS/lib64"
        fi
        ;;
esac

printf '%sPermissions fixed!%s\n' "$GREEN" "$RESET"


# Enter chroot and run install scripts
[ -f "$LFS/lfs-ai/scripts/toolchain-chroot" ] || \
    die "Missing chroot entry script: $LFS/lfs-ai/scripts/toolchain-chroot"

[ -x "$LFS/usr/bin/env" ] || die "Missing $LFS/usr/bin/env"

printf '\n%sEntering chroot...%s\n' "$MAGENTA" "$RESET"
chroot "$LFS" /usr/bin/env -i              \
    HOME=/root                             \
    TERM="${TERM:-xterm}"                  \
    PS1='(lfs chroot) \u:\w\$ '            \
    PATH=/usr/bin:/usr/sbin:/bin:/sbin     \
    MAKEFLAGS="$MAKE_JOBS"                 \
    TESTSUITEFLAGS="$MAKE_JOBS"            \
    /bin/bash ./lfs-ai/scripts/toolchain-chroot
