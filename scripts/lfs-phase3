#!/usr/bin/env bash
# LFS-AI - LFS Install Script
# Phase: LFS Phase 3
# Purpose: Install phase 3 of Linux from Scratch
# Safe rerun: Yes
# Copyright (c) 2026 Michael Femiak (Vercety1534)
# SPDX-License-Identifier: MIT

set -euo pipefail

RED=$'\033[31m'
RESET=$'\033[0m'

cd /lfs-ai

# Error handling
die() {
    printf '%sERROR:%s %s\n' "$RED" "$RESET" "$1" >&2
    exit 1
}

rm -rf /logs/lfs/phase3
mkdir -p /logs/lfs/phase3

[ -d /lfs-ai/lfs ] || die 'Missing /lfs-ai/lfs'

# Phase 3 install
shopt -s nullglob

found_script=0
for script in /lfs-ai/lfs/{030..042}-*; do
    if [[ -f "$script" && -x "$script" ]]; then
        found_script=1
        bash "$script"
    fi
done

if (( found_script != 1 )); then
    die 'No executable phase 3 scripts found in /lfs-ai/lfs'
fi
