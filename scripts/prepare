#!/usr/bin/env bash
# LFS-AI - Prepare Script
# Purpose: Prepare the host system and partition the drive
# Safe rerun: Conditionally (rerunnable, but always destructive)
# Copyright (c) 2026 Michael Femiak (Vercety1534)
# SPDX-License-Identifier: MIT

set -euo pipefail

umask 022

RED=$'\033[31m'
GREEN=$'\033[32m'
BLUE=$'\033[34m'
MAGENTA=$'\033[35m'
RESET=$'\033[0m'

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
base_dir="$(cd -- "$script_dir/.." && pwd)"


# Error handling
die() {
    printf '%sERROR:%s %s\n' "$RED" "$RESET" "$1" >&2
    exit 1
}


# Function to prompt user to continue
prompt_confirm() {
    local prompt="${1:-Continue?}"

    while true; do
        read -r -p "$prompt [y/N]: " REPLY
        case "$REPLY" in
            [yY]|[yY][eE][sS]) return 0 ;;
            [nN]|[nN][oO]|"") die "Aborted by user." ;;
            *) printf '%sERROR:%s invalid input\n' "$RED" "$RESET" ;;
        esac
    done
}


# Host system safety check
require_var() {
    [ -n "${!1:-}" ] || die "Required variable $1 is not set."
}

for var in DRIVE EFI SWAP MAIN EFI_SIZE SWAP_SIZE LFS LFS_PASS MAKE_JOBS; do
    require_var "$var"
done

get_parent_disk() {
    local dev="$1"
    local pkname

    [ -n "$dev" ] || return 1
    pkname="$(lsblk -no PKNAME "$dev" 2>/dev/null | head -n1)" || return 1

    if [ -n "$pkname" ]; then
        printf '/dev/%s\n' "$pkname"
    else
        printf '%s\n' "$dev"
    fi
}

ensure_not_system_disk() {
    local root_src boot_src efi_src
    local root_disk boot_disk efi_disk

    root_src="$(findmnt -n -o SOURCE / 2>/dev/null || true)"
    boot_src="$(findmnt -n -o SOURCE /boot 2>/dev/null || true)"
    efi_src="$(findmnt -n -o SOURCE /boot/efi 2>/dev/null || true)"

    root_disk="$(get_parent_disk "$root_src" || true)"
    boot_disk="$(get_parent_disk "$boot_src" || true)"
    efi_disk="$(get_parent_disk "$efi_src" || true)"

    [ -z "$root_disk" ] || [ "$DRIVE" != "$root_disk" ] || die "Refusing to use DRIVE because it backs the currently mounted / filesystem: $DRIVE"
    [ -z "$boot_disk" ] || [ "$DRIVE" != "$boot_disk" ] || die "Refusing to use DRIVE because it backs the currently mounted /boot filesystem: $DRIVE"
    [ -z "$efi_disk" ] || [ "$DRIVE" != "$efi_disk" ] || die "Refusing to use DRIVE because it backs the currently mounted /boot/efi filesystem: $DRIVE"
}

release_drive_usage() {
    local part mountpoint
    local swap_changes=0
    local mount_changes=0

    ensure_not_system_disk

    if grep -q "^$SWAP[[:space:]]" /proc/swaps; then
        printf '  - Disabling swap: %s\n' "$SWAP"
        swapoff "$SWAP" || die "Failed to disable swap on $SWAP"
        swap_changes=1
    fi

    while read -r part mountpoint || [ -n "$part" ]; do
        [ -n "$part" ] || continue
        case "$part" in
            "$DRIVE") continue ;;
            "$DRIVE"[0-9]*|"$DRIVE"p[0-9]*) ;;
            *) continue ;;
        esac
        case "$mountpoint" in
            /*)
                printf '  - Unmounting %s from %s\n' "$part" "$mountpoint"
                umount "$part" 2>/dev/null || umount -l "$part" || die "Failed to unmount $part"
                mount_changes=1
                ;;
        esac
    done < <(lsblk -nrpo NAME,MOUNTPOINT "$DRIVE")

    grep -q "^$SWAP[[:space:]]" /proc/swaps && die "Swap is still active on $SWAP"

    partprobe "$DRIVE" >/dev/null 2>&1 || true
    udevadm settle >/dev/null 2>&1 || true

    [ "$swap_changes" -eq 0 ] && [ "$mount_changes" -eq 0 ] && return 1
    return 0
}


# Wipe Drive
erase_drive() {
    case "$DRIVE" in
        /dev/nvme*)
            nvme format --force "$DRIVE" -s 2 -n 1 >/dev/null 2>&1 || true
            wipefs -afq "$DRIVE"
            ;;
        /dev/sd*|/dev/vd*|/dev/xvd*|/dev/mmcblk*)
            blkdiscard -f "$DRIVE" >/dev/null 2>&1 || true
            wipefs -afq "$DRIVE"
            ;;
        *)
            die "Unsupported drive type: $DRIVE"
            ;;
    esac
}


# Grant lfs build user permissions
grant_lfs_repo_access() {
    local repo_dir="$1"
    local dir

    [ -d "$repo_dir" ] || die "Repository directory not found: $repo_dir"

    dir="$(dirname "$repo_dir")"
    while [ "$dir" != "/" ]; do
        setfacl -m u:lfs:--x "$dir"
        dir="$(dirname "$dir")"
    done
    setfacl -m u:lfs:--x /

    setfacl -R -m u:lfs:rX "$repo_dir"
    setfacl -R -d -m u:lfs:rX "$repo_dir"
}




# Confirm installation configuration
printf '\n%sInstallation configuration:%s\n' "$MAGENTA" "$RESET"
printf 'Drive:           %s%s%s\n' "$BLUE" "$DRIVE" "$RESET"
printf 'EFI partition:   %s%s%s\n' "$BLUE" "$EFI" "$RESET"
printf 'SWAP partition:  %s%s%s\n' "$BLUE" "$SWAP" "$RESET"
printf 'ROOT partition:  %s%s%s\n' "$BLUE" "$MAIN" "$RESET"
printf 'EFI size:        %s%s%s\n' "$BLUE" "$EFI_SIZE" "$RESET"
printf 'Swap size:       %s%s%s\n' "$BLUE" "$SWAP_SIZE" "$RESET"
printf 'Mount point:     %s%s%s\n' "$BLUE" "$LFS" "$RESET"
printf 'MAKE_JOBS:       %s%s%s\n' "$BLUE" "$MAKE_JOBS" "$RESET"


# Execute disk preparation
printf '%sPreparing drive...%s\n\n' "$MAGENTA" "$RESET"
printf '%sWARNING:%s This will erase all data on %s\n' "$RED" "$RESET" "$DRIVE"
prompt_confirm "Proceed with disk wipe and partitioning?"

printf '%sReleasing target drive...%s\n' "$MAGENTA" "$RESET"
if release_drive_usage; then
    printf '%sTarget drive released successfully.%s\n' "$GREEN" "$RESET"
else
    printf '  - No active mounts or swap found on target drive\n'
    printf '%sTarget drive already clear.%s\n' "$GREEN" "$RESET"
fi

printf '\n%sWiping target drive...%s\n' "$MAGENTA" "$RESET"
erase_drive
printf '%sWipe successful!%s\n' "$GREEN" "$RESET"


# Create EFI | SWAP | 'Remaining' Linux partition
printf '\n%sPartitioning drive...%s\n' "$MAGENTA" "$RESET"
printf 'label:gpt\n' | sfdisk -q --force --wipe always "$DRIVE"
printf "size=$EFI_SIZE,type=uefi\n size=$SWAP_SIZE,type=swap\n size=+,type=4F68BCE3-E8CD-4DB1-96E7-FBCAF984B709\n" | sfdisk -q --force "$DRIVE"

for _ in 1 2 3 4 5; do
    [ -b "$EFI" ] && [ -b "$SWAP" ] && [ -b "$MAIN" ] && break
    sleep 1
done

[ -b "$EFI" ]  || die "EFI partition was not created: $EFI"
[ -b "$SWAP" ] || die "SWAP partition was not created: $SWAP"
[ -b "$MAIN" ] || die "MAIN partition was not created: $MAIN"
printf '%sPartitioning successful!%s\n' "$GREEN" "$RESET"


# Create File Systems
printf '\n%sFormatting partitions...%s\n' "$MAGENTA" "$RESET"
mkfs.fat -F 32 -n EFI "$EFI" > /dev/null 2>&1
mkswap -L SWAP "$SWAP" > /dev/null 2>&1
mkfs.ext4 -F -L LFS "$MAIN"  > /dev/null 2>&1
printf '%sFormat successful!%s\n' "$GREEN" "$RESET"

printf '\n%sMounting partitions...%s\n' "$MAGENTA" "$RESET"


# Mount Main Partition
mkdir -p "$LFS"
mount "$MAIN" "$LFS"


# Mount EFI Partition
mkdir -p "$LFS/boot"
mount "$EFI" "$LFS/boot"


# Mount SWAP Partition
swapon "$SWAP"
printf '%sMount successful!%s\n' "$GREEN" "$RESET"


# Fix permissions
chown --quiet root:root "$LFS"
chmod --quiet 755 "$LFS"


# Creating LFS directory structure
printf '\n%sCreating LFS directory structure...%s\n' "$MAGENTA" "$RESET"
mkdir -p "$LFS/sources"
chmod --quiet a+wt "$LFS/sources"

mkdir -p "$LFS/etc" "$LFS/logs" "$LFS/var" "$LFS/usr/bin" "$LFS/usr/sbin" "$LFS/usr/lib"

for i in bin lib sbin; do
  ln -sf "usr/$i" "$LFS/$i"
done

case $(uname -m) in
  x86_64) mkdir -p "$LFS/lib64" ;;
esac

mkdir -p "$LFS/tools"
printf '%sFile creation successful!%s\n' "$GREEN" "$RESET"


# Add the LFS user
printf '\n%sCreating build user...%s\n' "$MAGENTA" "$RESET"
if ! getent group lfs >/dev/null 2>&1; then
    printf '  - Creating group: lfs\n'
    groupadd lfs
else
    printf '  - Using existing group: lfs\n'
fi

if ! id -u lfs >/dev/null 2>&1; then
    printf '  - Creating user: lfs\n'
    useradd -s /bin/bash -g lfs -m -k /dev/null lfs
    printf 'lfs:%s\n' "$LFS_PASS" | chpasswd
else
    printf '  - Using existing user: lfs\n'
fi
printf '%sBuild user creation successful!%s\n' "$GREEN" "$RESET"

printf '\n%sSetting up the environment...%s\n' "$MAGENTA" "$RESET"

chown --quiet -R lfs "$LFS/usr" "$LFS/var" "$LFS/etc" "$LFS/logs" "$LFS/tools"

case $(uname -m) in
  x86_64) chown --quiet lfs "$LFS/lib64" ;;
esac

grant_lfs_repo_access "$base_dir"


# Setup the environment
cat > /home/lfs/.bash_profile << "EOF"
exec env -i HOME=$HOME TERM=$TERM PS1='\u:\w\$ ' /bin/bash
EOF

cat > /home/lfs/.bashrc << EOF
set +h
umask 022
LFS=$LFS
LC_ALL=POSIX
LFS_TGT=\$(uname -m)-lfs-linux-gnu
PATH=/usr/bin
if [ ! -L /bin ]; then PATH=/bin:\$PATH; fi
PATH=\$LFS/tools/bin:\$PATH
CONFIG_SITE=\$LFS/usr/share/config.site
export LFS LC_ALL LFS_TGT PATH CONFIG_SITE
export MAKEFLAGS=$MAKE_JOBS
EOF

if [ -e /etc/bash.bashrc ] && [ ! -e /etc/bash.bashrc.NOUSE ]; then
    mv /etc/bash.bashrc /etc/bash.bashrc.NOUSE
fi

printf '%sEnvironment setup successful! System preparation complete.%s\n' "$GREEN" "$RESET"
