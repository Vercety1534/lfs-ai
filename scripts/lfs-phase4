#!/usr/bin/env bash
# LFS-AI - LFS Install Script
# Phase: LFS Phase 4
# Purpose: Install phase 4 of Linux from Scratch
# Safe rerun: Yes
# Copyright (c) 2026 Michael Femiak (Vercety1534)
# SPDX-License-Identifier: MIT

set -e

cd /lfs-ai

rm -rf /logs/lfs/phase4
mkdir -p /logs/lfs/phase4

[ -d /lfs-ai/lfs ] || {
    printf "\033[31m[ERROR] Missing /lfs-ai/lfs\033[0m\n" >&2
    exit 1
}

# Phase 4 install
shopt -s nullglob

for script in /lfs-ai/lfs/{043..072}-*; do
    [ -f "$script" ] && [ -x "$script" ] && bash "$script"
done
