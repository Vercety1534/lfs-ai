#!/usr/bin/env bash
# LFS-AI - Verification Script
# Purpose: Verify dependencies on host system
# Safe rerun: Yes
# Copyright (c) 2026 Michael Femiak (Vercety1534)
# SPDX-License-Identifier: MIT

set -euo pipefail

umask 022

RED=$'\033[31m'
GREEN=$'\033[32m'
BLUE=$'\033[34m'
MAGENTA=$'\033[35m'
RESET=$'\033[0m'

WARNED=0
FAILED=0

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

export LC_ALL=C
export PATH


bail() { printf '%sERROR:%s %b\n' "$RED" "$RESET" "$1"; exit 1; }
grep --version > /dev/null 2> /dev/null || bail "grep does not work\n"
sed -n '' /dev/null || bail "sed does not work\n"
sort   /dev/null || bail "sort does not work\n"


version_ge() {
    local IFS=.
    local i
    local -a found required

    read -r -a found <<< "${1//[^0-9.]/}"
    read -r -a required <<< "${2//[^0-9.]/}"

    for ((i=0; i<${#found[@]} || i<${#required[@]}; i++)); do
        local f="${found[i]:-0}"
        local r="${required[i]:-0}"

        if ((10#$f > 10#$r)); then
            return 0
        fi
        if ((10#$f < 10#$r)); then
            return 1
        fi
    done

    return 0
}

detect_impl() {
    local cmd="$1"
    local line

    if ! type -p "$cmd" >/dev/null 2>&1; then
        printf 'missing\n'
        return 0
    fi

    line="$("$cmd" --version 2>&1 | head -n1 || true)"

    case "$line" in
        *" not GNU sed version "*)
            printf 'busybox\n'
            ;;
        *"uutils"*)
            printf 'uutils\n'
            ;;
        *"BusyBox"*)
            printf 'busybox\n'
            ;;
        *"GNU coreutils"*|*"GNU "*|*"GNU"*)
            printf 'gnu\n'
            ;;
        *)
            if "$cmd" --help 2>&1 | grep -qi 'BusyBox'; then
                printf 'busybox\n'
            else
                printf 'unknown\n'
            fi
            ;;
    esac
}

check_impl_tool() {
    local label="$1"
    local cmd="$2"
    local min="$3"
    local impl v

    impl="$(detect_impl "$cmd")"

    case "$impl" in
        gnu)
            v=$("$cmd" --version 2>&1 | grep -E -o '[0-9]+\.[0-9.]+[a-z]*' | head -n1)
            if [ -z "$v" ]; then
                printf '%sERROR:%s %-12s    version could not be detected\n' "$RED" "$RESET" "$label"
                FAILED=1
                return 1
            fi
            if version_ge "$v" "$min"; then
                printf '%sOK:%s    %-12s    %-6s    >=    %-6s    (GNU)\n' "$GREEN" "$RESET" "$label" "$v" "$min"
                return 0
            fi
            printf '%sERROR:%s %-12s    is TOO OLD (%s or later required)\n' "$RED" "$RESET" "$label" "$min"
            FAILED=1
            return 1
            ;;
        uutils)
            WARNED=1
            printf '%sWARN:%s  %-12s    uutils implementation detected\n' "$MAGENTA" "$RESET" "$label"
            return 0
            ;;
        busybox)
            WARNED=1
            printf '%sWARN:%s  %-12s    BusyBox implementation detected\n' "$MAGENTA" "$RESET" "$label"
            return 0
            ;;
        missing)
            printf '%sERROR:%s %-12s    missing\n' "$RED" "$RESET" "$label"
            FAILED=1
            return 1
            ;;
        *)
            WARNED=1
            printf '%sWARN:%s  %-12s    unknown implementation detected\n' "$MAGENTA" "$RESET" "$label"
            return 0
            ;;
    esac
}

ver_check() {
   local name="$1"
   local cmd="$2"
   local min="$3"
   local v

   if ! type -p "$cmd" >/dev/null 2>&1; then
      printf '%sERROR:%s Cannot find %s (%s)\n' "$RED" "$RESET" "$cmd" "$name"
      FAILED=1
      return 1
   fi

   v=$("$cmd" --version 2>&1 | grep -E -o '[0-9]+\.[0-9.]+[a-z]*' | head -n1)

   if [ -z "$v" ]; then
      printf '%sERROR:%s %-10s    version could not be detected\n' "$RED" "$RESET" "$name"
      FAILED=1
      return 1
   fi

   if version_ge "$v" "$min"; then
      printf '%sOK:%s    %-12s    %-6s    >=    %s\n' "$GREEN" "$RESET" "$name" "$v" "$min"
      return 0
   else
      printf '%sERROR:%s %-12s    is TOO OLD (%s or later required)\n' "$RED" "$RESET" "$name" "$min"
      FAILED=1
      return 1
   fi
}

need_nvme_version() {
   if compgen -G '/dev/nvme*n1' >/dev/null; then
      ver_check 'NVMe-CLI' nvme 1.9
   else
      printf '%sSKIP:%s  %-12s    no NVMe device detected\n' "$BLUE" "$RESET" 'NVMe-CLI'
   fi
}

need_cmd() {
   local name="$1"
   local cmd="$2"

   if type -p "$cmd" >/dev/null 2>&1; then
      printf '%sOK:%s    %-14s  Found\n' "$GREEN" "$RESET" "$name"
      return 0
   else
      printf '%sERROR:%s %-14s  Missing\n' "$RED" "$RESET" "$name"
      FAILED=1
      return 1
   fi
}

need_linux_headers() {
    if [ -f /usr/include/linux/perf_event.h ] && [ -f /usr/include/linux/limits.h ]; then
        printf '%sOK:%s    %-14s  Found\n' "$GREEN" "$RESET" "Linux headers"
        return 0
    else
        printf '%sERROR:%s %-14s  Missing required kernel headers under /usr/include/linux\n' \
            "$RED" "$RESET" "Linux headers"
        FAILED=1
        return 1
    fi
}

need_gettext_headers() {
    if [ -f /usr/include/libintl.h ]; then
        printf '%sOK:%s    %-14s Found\n' "$GREEN" "$RESET" "Gettext headers"
        return 0
    else
        printf '%sERROR:%s %-14s Missing (/usr/include/libintl.h)\n' \
            "$RED" "$RESET" "Gettext headers"
        FAILED=1
        return 1
    fi
}

ver_kernel() {
   local min="$1"
   local kver

   kver=$(uname -r | grep -E -o '^[0-9.]+')

   if version_ge "$kver" "$min"; then
      printf '%sOK:%s    Linux Kernel  %-6s    >=    %s\n' "$GREEN" "$RESET" "$kver" "$min"
      return 0
   else
      printf '%sERROR:%s Linux Kernel (%s) is TOO OLD (%s or later required)\n' "$RED" "$RESET" "$kver" "$min"
      FAILED=1
      return 1
   fi
}

check_unix98_pty() {
    if type -p zgrep >/dev/null 2>&1 && zgrep -Eq '^CONFIG_UNIX98_PTYS=y' /proc/config.gz 2>/dev/null; then
        printf '%sOK:%s    UNIX 98 PTY support enabled in kernel\n' "$GREEN" "$RESET"
        return 0
    elif grep -Eq '^CONFIG_UNIX98_PTYS=y' "/boot/config-$(uname -r)" 2>/dev/null; then
        printf '%sOK:%s    UNIX 98 PTY support enabled in kernel\n' "$GREEN" "$RESET"
        return 0
    elif [ -c /dev/ptmx ]; then
        printf '%sOK:%s    /dev/ptmx exists (kernel support likely present)\n' "$GREEN" "$RESET"
        return 0
    else
        printf '%sERROR:%s UNIX 98 PTY support could not be confirmed\n' "$RED" "$RESET"
        FAILED=1
        return 1
    fi
}

check_sh_impl() {
   local sh_path line impl

   sh_path="$(type -p sh 2>/dev/null || true)"

   if [ -z "$sh_path" ]; then
      WARNED=1
      printf '%sWARN:%s  sh   is missing\n' "$MAGENTA" "$RESET"
      return 0
   fi

   line="$(sh --version 2>&1 | head -n1 || true)"

   case "$line" in
      *"GNU bash"*)
         printf '%sOK:%s    sh   is Bash\n' "$GREEN" "$RESET"
         ;;
      *"dash"*)
         WARNED=1
         printf '%sWARN:%s  sh   is dash, not Bash\n' "$MAGENTA" "$RESET"
         ;;
      *"BusyBox"*)
         WARNED=1
         printf '%sWARN:%s  sh   is BusyBox ash, not Bash\n' "$MAGENTA" "$RESET"
         ;;
      *)
         if [ -L "$sh_path" ]; then
            impl="$(readlink -f "$sh_path" 2>/dev/null || printf '%s' "$sh_path")"
            WARNED=1
            printf '%sWARN:%s  sh   is not Bash (%s)\n' "$MAGENTA" "$RESET" "$impl"
         else
            WARNED=1
            printf '%sWARN:%s  sh   implementation could not be identified\n' "$MAGENTA" "$RESET"
         fi
         ;;
   esac
}

check_awk_impl() {
   local line impl

   if ! type -p awk >/dev/null 2>&1; then
      WARNED=1
      printf '%sWARN:%s  awk  is missing\n' "$MAGENTA" "$RESET"
      return 0
   fi

   line="$(awk --version 2>&1 | head -n1 || true)"

   case "$line" in
      *"GNU Awk"*|*"GNU awk"*|*"gawk"*)
         printf '%sOK:%s    awk  is GNU\n' "$GREEN" "$RESET"
         ;;
      *"BusyBox"*)
         WARNED=1
         printf '%sWARN:%s  awk  is BusyBox, not GNU awk\n' "$MAGENTA" "$RESET"
         ;;
      *)
         impl="$(type -p awk 2>/dev/null || printf 'awk')"
         WARNED=1
         printf '%sWARN:%s  awk  is NOT GNU (%s)\n' "$MAGENTA" "$RESET" "$impl"
         ;;
   esac
}

check_yacc_impl() {
   local line impl

   if ! type -p yacc >/dev/null 2>&1; then
      WARNED=1
      printf '%sWARN:%s  yacc is missing\n' "$MAGENTA" "$RESET"
      return 0
   fi

   line="$(yacc --version 2>&1 | head -n1 || true)"

   case "$line" in
      *"bison"*|*"Bison"*)
         printf '%sOK:%s    yacc is Bison\n' "$GREEN" "$RESET"
         ;;
      *)
         impl="$(type -p yacc 2>/dev/null || printf 'yacc')"
         WARNED=1
         printf '%sWARN:%s  yacc is NOT Bison (%s)\n' "$MAGENTA" "$RESET" "$impl"
         ;;
   esac
}




# Coreutils first because sort is used as the representative implementation check
printf '\n%sPackages:%s\n' "$BLUE" "$RESET"
check_impl_tool Coreutils      sort     8.25      || true
ver_check       Acl            setfacl  2.2.49    || true
ver_check       Bash           bash     3.2       || true
ver_check       Binutils       ld       2.13.1    || true
ver_check       Bison          bison    2.7       || true
check_impl_tool Diffutils      diff     2.8.1     || true
ver_check       Dosfstools     mkfs.fat 3.0.28    || true
need_cmd        E2fsprogs      mkfs.ext4          || true
check_impl_tool Findutils      find     4.2.31    || true
ver_check       Gawk           gawk     4.0.1     || true
ver_check       GCC            gcc      7.0       || true
ver_check       "GCC (C++)"    g++      7.0       || true
need_gettext_headers
ver_check       Grep           grep     2.5.1a    || true
ver_check       Gzip           gzip     1.3.12    || true
need_linux_headers
ver_check       M4             m4       1.4.10    || true
ver_check       Make           make     4.0       || true
need_nvme_version                                 || true
ver_check       Patch          patch    2.5.4     || true
ver_check       Perl           perl     5.8.8     || true
ver_check       Python         python3  3.6       || true
check_impl_tool Sed            sed      4.1.5     || true
need_cmd        Shadow         useradd            || true
ver_check       Tar            tar      1.22      || true
ver_check       Texinfo        texi2any 5.0       || true
ver_check       Util-linux     lsblk    2.26      || true
ver_check       Wget           wget     1.16.0    || true
ver_check       Xz             xz       5.0.0     || true

printf '\n%sKernel:%s\n' "$BLUE" "$RESET"
ver_kernel 5.4                                    || true
check_unix98_pty                                  || true

printf '\n%sCompatibility:%s\n' "$BLUE" "$RESET"
check_awk_impl
check_yacc_impl
check_sh_impl

printf '\n%sCompiler:%s\n' "$BLUE" "$RESET"
tmp_cpp="$(mktemp /tmp/lfs-ai-verify-cpp-XXXXXX)"
tmp_bin="$(mktemp /tmp/lfs-ai-verify-bin-XXXXXX)"
mv "$tmp_cpp" "${tmp_cpp}.cpp"
tmp_cpp="${tmp_cpp}.cpp"
rm -f "$tmp_bin"
printf 'int main(){}\n' > "$tmp_cpp"

if ! type -p g++ >/dev/null 2>&1; then
    printf '%sERROR:%s g++ is missing\n' "$RED" "$RESET"
    FAILED=1
elif g++ -x c++ "$tmp_cpp" -o "$tmp_bin"; then
    printf '%sOK:%s    g++ works\n' "$GREEN" "$RESET"
else
    printf '%sERROR:%s g++ does NOT work\n' "$RED" "$RESET"
    FAILED=1
fi

rm -f "$tmp_cpp" "$tmp_bin"

cores="$(nproc 2>/dev/null || true)"
if [ -z "$cores" ]; then
   printf '%sERROR:%s    nproc is not available or it produces empty output\n' "$RED" "$RESET"
   FAILED=1
else
   printf '%sOK:%s    nproc reports %s logical cores are available\n' "$GREEN" "$RESET" "$cores"
fi

if [ "$FAILED" -ne 0 ]; then
    printf '\n%sERROR:%s One or more verification checks failed.\n' "$RED" "$RESET"
    exit 1
fi

if [ "${WARNED:-0}" -ne 0 ]; then
    printf '\n%sSuccess:%s Host system passed verification with warnings.\n' "$GREEN" "$RESET"
else
    printf '\n%sSuccess:%s Host system passed verification.\n' "$GREEN" "$RESET"
fi

