#!/usr/bin/env bash
# LFS-AI - Verification Script
# Purpose: Verify dependencies on host system
# Safe rerun: Yes
# Copyright (c) 2026 Michael Femiak (Vercety1534)
# SPDX-License-Identifier: MIT

set -e

umask 022

RED='\033[31m'
GREEN='\033[32m'
BLUE='\033[34m'
MAGENTA='\033[35m'
RESET='\033[0m'

FAILED=0

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

export LC_ALL=C
export PATH




bail() { printf "${RED}ERROR:${RESET} %s" "$1"; exit 1; }
grep --version > /dev/null 2> /dev/null || bail "grep does not work\n"
sed -n '' /dev/null || bail "sed does not work\n"
sort   /dev/null || bail "sort does not work\n"




ver_check() {
   local name="$1"
   local cmd="$2"
   local min="$3"
   local v

   if ! type -p "$cmd" >/dev/null 2>&1; then
      printf "${RED}ERROR:${RESET} Cannot find %s (%s)\n" "$cmd" "$name"
      FAILED=1
      return 1
   fi

   v=$("$cmd" --version 2>&1 | grep -E -o '[0-9]+\.[0-9.]+[a-z]*' | head -n1)

   if [ -z "$v" ]; then
      printf "${RED}ERROR:${RESET} %-10s    version could not be detected\n" "$name"
      FAILED=1
      return 1
   fi

   if printf '%s\n' "$min" "$v" | sort --version-sort --check >/dev/null 2>&1; then
      printf "${GREEN}OK:${RESET}    %-10s    %-6s    >=    %s\n" "$name" "$v" "$min"
      return 0
   else
      printf "${RED}ERROR:${RESET} %-10s    is TOO OLD (%s or later required)\n" "$name" "$min"
      FAILED=1
      return 1
   fi
}

ver_kernel() {
   local min="$1"
   local kver

   kver=$(uname -r | grep -E -o '^[0-9.]+')

   if printf '%s\n' "$min" "$kver" | sort --version-sort --check >/dev/null 2>&1; then
      printf "${GREEN}OK:${RESET}    Linux Kernel  %-6s    >=    %s\n" "$kver" "$min"
      return 0
   else
      printf "${RED}ERROR:${RESET} Linux Kernel (%s) is TOO OLD (%s or later required)\n" "$kver" "$min"
      FAILED=1
      return 1
   fi
}

check_unix98_pty() {
    if type -p zgrep >/dev/null 2>&1 && zgrep -Eq '^CONFIG_UNIX98_PTYS=y' /proc/config.gz 2>/dev/null; then
        printf "${GREEN}OK:${RESET}    UNIX 98 PTY support enabled in kernel\n"
        return 0
    elif grep -Eq '^CONFIG_UNIX98_PTYS=y' "/boot/config-$(uname -r)" 2>/dev/null; then
        printf "${GREEN}OK:${RESET}    UNIX 98 PTY support enabled in kernel\n"
        return 0
    elif [ -c /dev/ptmx ]; then
        printf "${GREEN}OK:${RESET}    /dev/ptmx exists (kernel support likely present)\n"
        return 0
    else
        printf "${RED}ERROR:${RESET} UNIX 98 PTY support could not be confirmed\n"
        FAILED=1
        return 1
    fi
}

need_cmd() {
   local name="$1"
   local cmd="$2"

   if type -p "$cmd" >/dev/null 2>&1; then
      printf "${GREEN}OK:${RESET}    %-12s  Found\n" "$name"
      return 0
   else
      printf "${RED}ERROR:${RESET} %-12s  Missing\n" "$name"
      FAILED=1
      return 1
   fi
}

need_nvme_version() {
   local name="$1"
   local cmd="$2"
   local min="$3"
   local v

   if ls /dev/nvme* >/dev/null 2>&1; then
      if ! type -p "$cmd" >/dev/null 2>&1; then
         printf "${RED}ERROR:${RESET} nvme-cli is required for NVMe devices but is not installed.\n"
         FAILED=1
         return 1
      fi

      v=$("$cmd" --version 2>&1 | grep -E -o '[0-9]+\.[0-9.]+[a-z]*' | head -n1)

      if [ -z "$v" ]; then
         printf "${RED}ERROR:${RESET} %-10s    version could not be detected\n" "$name"
         FAILED=1
         return 1
      fi

      if printf '%s\n' "$min" "$v" | sort --version-sort --check >/dev/null 2>&1; then
         printf "${GREEN}OK:${RESET}    %-10s    %-6s    >=    %s\n" "$name" "$v" "$min"
         return 0
      else
         printf "${RED}ERROR:${RESET} %-10s    is TOO OLD (%s or later required)\n" "$name" "$min"
         FAILED=1
         return 1
      fi
   else
      printf "${GREEN}OK:${RESET} No NVMe devices found on this system\n"
      return 0
   fi
}

# Coreutils first because --version-sort needs Coreutils >= 7.0
printf "\n${BLUE}Packages:${RESET}\n"
ver_check Coreutils      sort     8.25      || bail "Coreutils too old, stop\n"
ver_check Acl            setfacl  2.2.49    || true
ver_check Bash           bash     3.2       || true
ver_check Binutils       ld       2.13.1    || true
ver_check Bison          bison    2.7       || true
ver_check Diffutils      diff     2.8.1     || true
ver_check Dosfstools     mkfs.fat 3.0.28    || true
need_cmd  E2fsprogs      mkfs.ext4          || true
ver_check Findutils      find     4.2.31    || true
ver_check Gawk           gawk     4.0.1     || true
ver_check GCC            gcc      7.0       || true
ver_check "GCC (C++)"    g++      7.0       || true
ver_check Grep           grep     2.5.1a    || true
ver_check Gzip           gzip     1.3.12    || true
ver_check M4             m4       1.4.10    || true
ver_check Make           make     4.0       || true
need_nvme_version nvme-cli   nvme     1.9.0 || true
ver_check Patch          patch    2.5.4     || true
ver_check Perl           perl     5.8.8     || true
ver_check Python         python3  3.6       || true
ver_check Sed            sed      4.1.5     || true
need_cmd  Shadow         useradd            || true
ver_check Tar            tar      1.22      || true
ver_check Texinfo        texi2any 5.0       || true
ver_check Util-linux     lsblk    2.26      || true
ver_check Wget           wget     1.16.0    || true
ver_check Xz             xz       5.0.0     || true

printf "\n${BLUE}Kernel:${RESET}\n"
ver_kernel 5.4                              || true
check_unix98_pty                            || true




alias_check() {
   if ! type -p "$1" >/dev/null 2>&1; then
      printf "${RED}ERROR:${RESET} %-4s is missing\n" "$1"
      FAILED=1
      return 1
   fi

   if "$1" --version 2>&1 | grep -qi -- "$2"; then
      printf "${GREEN}OK:${RESET}    %-4s is %s\n" "$1" "$2"
      return 0
   else
      printf "${RED}ERROR:${RESET} %-4s is NOT %s\n" "$1" "$2"
      FAILED=1
      return 1
   fi
}

printf "\n${BLUE}Aliases:${RESET}\n"
alias_check awk  GNU   || true
alias_check yacc Bison || true
alias_check sh   Bash  || true




printf "\n${BLUE}Compiler:${RESET}\n"
tmp_cpp="$(mktemp --suffix=.cpp)"
tmp_bin="$(mktemp)"
rm -f "$tmp_bin"
printf 'int main(){}\n' > "$tmp_cpp"

if g++ -x c++ "$tmp_cpp" -o "$tmp_bin"; then
   printf "${GREEN}OK:${RESET}    g++ works\n"
else
   printf "${RED}ERROR:${RESET} g++ does NOT work\n"
   rm -f "$tmp_cpp" "$tmp_bin"
   FAILED=1
fi

rm -f "$tmp_cpp" "$tmp_bin"

cores="$(nproc 2>/dev/null || true)"
if [ -z "$cores" ]; then
   printf "${RED}ERROR:${RESET}    nproc is not available or it produces empty output\n"
   FAILED=1
else
   printf "${GREEN}OK:${RESET}    nproc reports %s logical cores are available\n" "$cores"
fi




if [ "$FAILED" -ne 0 ]; then
    printf "\n${RED}ERROR:${RESET} One or more verification checks failed.\n"
    exit 1
fi

printf "\n${GREEN}Success:${RESET} Host system passed verification.\n"

unset LC_ALL PATH
