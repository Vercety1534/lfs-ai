#!/usr/bin/env bash
# LFS-AI - LFS Install Script
# Phase: LFS Phase 1
# Purpose: Install phase 1 of Linux from Scratch
# Safe rerun: Yes
# Copyright (c) 2026 Michael Femiak (Vercety1534)
# SPDX-License-Identifier: MIT

set -euo pipefail

RED=$'\033[31m'
RESET=$'\033[0m'

LOG_DIR="/var/log/lfs-ai/lfs/phase1"

cd /lfs-ai

# Error handling
die() {
    printf '%sERROR:%s %s\n' "$RED" "$RESET" "$1" >&2
    exit 1
}

rm -rf "$LOG_DIR"
mkdir -p "$LOG_DIR"

[ -d /lfs-ai/lfs ] || die 'Missing /lfs-ai/lfs'

# Phase 1 install
shopt -s nullglob

found_script=0
for script in /lfs-ai/lfs/{001..003}-*; do
    if [[ -f "$script" && -x "$script" ]]; then
        found_script=1
        bash "$script"
    fi
done

if (( found_script != 1 )); then
    die 'No executable phase 1 scripts found in /lfs-ai/lfs'
fi
