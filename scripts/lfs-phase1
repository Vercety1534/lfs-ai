#!/usr/bin/env bash
# LFS-AI - LFS Install Script
# Phase: LFS Phase 1
# Purpose: Install phase 1 of Linux from Scratch
# Safe rerun: Yes
# Copyright (c) 2026 Michael Femiak (Vercety1534)
# SPDX-License-Identifier: MIT

set -e

cd /lfs-ai

rm -rf /logs/lfs/phase1
mkdir -p /logs/lfs/phase1

[ -d /lfs-ai/lfs ] || {
    printf "\033[31m[ERROR] Missing /lfs-ai/lfs\033[0m\n" >&2
    exit 1
}

# Phase 1 install
shopt -s nullglob

found_script=0
for script in /lfs-ai/lfs/{001..003}-*; do
    [ -f "$script" ] && [ -x "$script" ] || continue
    found_script=1
    bash "$script"
done

[ "$found_script" -eq 1 ] || {
    printf "\033[31m[ERROR] No executable phase 1 scripts found in /lfs-ai/lfs\033[0m\n" >&2
    exit 1
}