#!/usr/bin/env bash
# LFS-AI - Toolchain Script
# Purpose: Install the toolchain
# Safe rerun: Yes
# Copyright (c) 2026 Michael Femiak (Vercety1534)
# SPDX-License-Identifier: MIT

set -euo pipefail

umask 022

RED=$'\033[31m'
GREEN=$'\033[32m'
BLUE=$'\033[34m'
MAGENTA=$'\033[35m'
RESET=$'\033[0m'

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
base_dir="$(cd -- "$script_dir/.." && pwd)"
SCRIPT_PATH="$(readlink -f "$0")"


# Error handling
die() {
    printf '%sERROR:%s %s\n' "$RED" "$RESET" "$1" >&2
    exit 1
}


# Required inputs
require_var() {
    [ -n "${!1:-}" ] || die "Required variable $1 is not set."
}

for var in LFS; do
    require_var "$var"
done




# Verify runtime prerequisites and re-exec as lfs
if [ "${1:-}" != "--as-lfs" ]; then
    id lfs >/dev/null 2>&1 || die 'User lfs does not exist. Run prepare first.'
    [ -f /home/lfs/.bashrc ] || die 'Missing /home/lfs/.bashrc. Run prepare first.'
    exec runuser -u lfs -- /bin/bash "$SCRIPT_PATH" --as-lfs
fi

source /home/lfs/.bashrc

[ -d "$LFS/logs" ] || die "Missing logs directory: $LFS/logs"
rm -rf "$LFS/logs/toolchain"
mkdir -p "$LFS/logs/toolchain"


# Run install scripts
found_script=0
shopt -s nullglob

for script in "$base_dir"/cross-toolchain/*; do
    if [[ -f "$script" && -x "$script" ]]; then
        found_script=1
        bash "$script"
    fi
done

if (( found_script != 1 )); then
    die "No executable toolchain scripts found in $base_dir/cross-toolchain"
fi
