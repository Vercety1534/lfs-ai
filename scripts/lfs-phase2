#!/usr/bin/env bash
# LFS-AI - LFS Install Script
# Phase: LFS Phase 2
# Purpose: Install phase 2 of Linux from Scratch
# Safe rerun: Yes
# Copyright (c) 2026 Michael Femiak (Vercety1534)
# SPDX-License-Identifier: MIT

set -euo pipefail

RED=$'\033[31m'
RESET=$'\033[0m'

cd /lfs-ai

# Error handling
die() {
    printf '%sERROR:%s %s\n' "$RED" "$RESET" "$1" >&2
    exit 1
}

# Required inputs
require_var() {
    [ -n "${!1:-}" ] || die "Required variable $1 is not set."
}

for var in ROOT_PASS; do
    require_var "$var"
done

export ROOT_PASS

rm -rf /logs/lfs/phase2
mkdir -p /logs/lfs/phase2

[ -d /lfs-ai/lfs ] || die 'Missing /lfs-ai/lfs'

# Phase 2 install
shopt -s nullglob

found_script=0
for script in /lfs-ai/lfs/{004..029}-*; do
    if [[ -f "$script" && -x "$script" ]]; then
        found_script=1
        bash "$script"
    fi
done

if (( found_script != 1 )); then
    die 'No executable phase 2 scripts found in /lfs-ai/lfs'
fi
