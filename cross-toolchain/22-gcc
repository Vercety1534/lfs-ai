set -euo pipefail

PACKAGE=gcc
VERSION=15.2.0

RED=$'\033[31m'
GREEN=$'\033[32m'
BLUE=$'\033[34m'
MAGENTA=$'\033[35m'
RESET=$'\033[0m'


# Error handling
die() {
    printf '%sERROR:%s %s\n' "$RED" "$RESET" "$1" >&2
    exit 1
}

[ -n "${LFS:-}" ] || die 'LFS is not set.'
[ -n "${LFS_TGT:-}" ] || die 'LFS_TGT is not set.'


# Log command
LOG_DIR="$LFS/var/log/lfs-ai/toolchain"
LOG_FILE="$LOG_DIR/$PACKAGE-$VERSION-phase2.log"

run_log() {
    if "$@" >> "$LOG_FILE" 2>&1; then
        return 0
    else
        printf '%sERROR:%s %s failed. See %s\n' "$RED" "$RESET" "$*" "$LOG_FILE" >&2
        return 1
    fi
}


[ -f "$LFS/sources/$PACKAGE-$VERSION.tar.xz" ] || die "Missing source archive: $LFS/sources/$PACKAGE-$VERSION.tar.xz"
[ -f "$LFS/sources/mpfr-4.2.2.tar.xz" ] || die "Missing source archive: $LFS/sources/mpfr-4.2.2.tar.xz"
[ -f "$LFS/sources/gmp-6.3.0.tar.xz" ] || die "Missing source archive: $LFS/sources/gmp-6.3.0.tar.xz"
[ -f "$LFS/sources/mpc-1.4.0.tar.xz" ] || die "Missing source archive: $LFS/sources/mpc-1.4.0.tar.xz"

cd "$LFS/sources"

rm -rf "$PACKAGE-$VERSION"
tar -xf "$PACKAGE-$VERSION.tar.xz"
cd "$LFS/sources/$PACKAGE-$VERSION"

tar -xf ../mpfr-4.2.2.tar.xz
mv mpfr-4.2.2 mpfr
tar -xf ../gmp-6.3.0.tar.xz
mv gmp-6.3.0 gmp
tar -xf ../mpc-1.4.0.tar.xz
mv mpc-1.4.0 mpc

case "$(uname -m)" in
    x86_64)
        sed -e '/m64=/s/lib64/lib/' \
            -i.orig gcc/config/i386/t-linux64
        ;;
esac

sed '/thread_header =/s/@.*@/gthr-posix.h/' \
    -i libgcc/Makefile.in libstdc++-v3/include/Makefile.in

mkdir -p build
cd       build

printf '%sConfiguring %s phase 2...%s\n' "$MAGENTA" "$PACKAGE" "$RESET"
run_log env LDFLAGS_FOR_TARGET="-L$PWD/$LFS_TGT/libgcc" \
        ../configure                 \
        --build="$(../config.guess)" \
        --host="$LFS_TGT"            \
        --target="$LFS_TGT"          \
        --prefix=/usr                \
        --with-build-sysroot="$LFS"  \
        --enable-default-pie         \
        --enable-default-ssp         \
        --disable-nls                \
        --disable-multilib           \
        --disable-libatomic          \
        --disable-libgomp            \
        --disable-libquadmath        \
        --disable-libsanitizer       \
        --disable-libssp             \
        --disable-libvtv             \
        --enable-plugins             \
        --enable-lto                 \
        --enable-languages=c,c++,lto
printf '%sConfiguration successful!%s\n' "$GREEN" "$RESET"

printf '%sBuilding %s phase 2...%s\n' "$MAGENTA" "$PACKAGE" "$RESET"
run_log make
printf '%sBuild successful!%s\n' "$GREEN" "$RESET"

printf '%sInstalling %s phase 2...%s\n' "$MAGENTA" "$PACKAGE" "$RESET"
run_log make DESTDIR="$LFS" install

run_log ln -svf gcc "$LFS/usr/bin/cc"
printf '%sInstall successful!%s\n\n\n' "$GREEN" "$RESET"

cd "$LFS/sources"
rm -rf "$PACKAGE-$VERSION"
