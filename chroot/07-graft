set -euo pipefail

PACKAGE=graft
VERSION=2.16

RED=$'\033[31m'
GREEN=$'\033[32m'
BLUE=$'\033[34m'
MAGENTA=$'\033[35m'
RESET=$'\033[0m'


# Error handling
die() {
    printf '%sERROR:%s %s\n' "$RED" "$RESET" "$1" >&2
    exit 1
}


# Log command
LOG_DIR="/var/log/lfs-ai/chroot"
LOG_FILE="$LOG_DIR/$PACKAGE-$VERSION.log"

run_log() {
    if "$@" >> "$LOG_FILE" 2>&1; then
        return 0
    else
        printf '%sERROR:%s %s failed. See %s\n' "$RED" "$RESET" "$*" "$LOG_FILE" >&2
        return 1
    fi
}

run_log_error() {
    if "$@" >> "$LOG_FILE" 2>&1; then
        return 0
    else
        printf '%sINFO:%s Non-zero exit expected here; continuing.\n' "$MAGENTA" "$RESET" >&2
        return 1
    fi
}


[ -f "/sources/$VERSION.tar.gz" ] || die "Missing source archive: /sources/$VERSION.tar.gz"

cd /sources

rm -rf "$PACKAGE-$VERSION"
tar -xf "$VERSION.tar.gz"
cd "/sources/$PACKAGE-$VERSION"

printf '%sConfiguring %s...%s\n' "$MAGENTA" "$PACKAGE" "$RESET"
set +e
run_log_error make -f Makefile.dist
set -e

sed -i \
  -e 's|^PACKAGEDIR[[:space:]]*=.*|PACKAGEDIR = /usr/pkg|' \
  -e 's|^TARGETDIR[[:space:]]*=.*|TARGETDIR = /|' \
  -e 's|^BIN[[:space:]]*=.*|BIN = $(TOP)/usr/bin|' \
  -e 's|^MAN[[:space:]]*=.*|MAN = $(TOP)/usr/share/man|' \
  -e 's|^DOC[[:space:]]*=.*|DOC = $(TOP)/usr/share/doc/graft-2.16|' \
  Makefile
printf '%sConfiguration successful!%s\n' "$GREEN" "$RESET"

printf '%sBuilding %s...%s\n' "$MAGENTA" "$PACKAGE" "$RESET"
run_log make
printf '%sBuild successful!%s\n' "$GREEN" "$RESET"

printf '%sInstalling %s...%s\n' "$MAGENTA" "$PACKAGE" "$RESET"
run_log make install

rm -f /usr/pkg/"$PACKAGE-$VERSION"/usr/share/doc/"$PACKAGE-$VERSION"/.nograft

run_log /usr/pkg/"$PACKAGE-$VERSION"/usr/bin/graft -iV "$PACKAGE-$VERSION"
printf '%sInstall successful!%s\n\n\n' "$GREEN" "$RESET"

cd /sources
rm -rf "$PACKAGE-$VERSION"
